<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <GVL Name="GVL" Id="{f20f1905-5880-4192-9280-dc27597430f4}">
    <Declaration><![CDATA[VAR_GLOBAL
    AdlOn: ARRAY[0..19] OF BOOL;          (** Active dummy load control status: 0 = off/not supported, 1 = on **)
    AlarmStatus: UINT;                    (** Bitmask of active alarms, 1 bit per device **)
    Bus1_Devices AT %Q*: ARRAY[0..3] OF TxData; (** CAN Bus 1 Tx data for devices 0-3 **)
    Bus1_Devices_DLC3 AT %Q*: ARRAY[0..3] OF TxData; (** CAN Bus 1 DLC 3 commands **)
    Bus1_Devices_DLC4 AT %Q*: ARRAY[0..3] OF TxData; (** CAN Bus 1 DLC 4 commands **)
    Bus1_Devices_Rx AT %I*: ARRAY[0..3] OF RxData; (** CAN Bus 1 Rx data **)
    Bus2_Devices AT %Q*: ARRAY[0..7] OF TxData; (** CAN Bus 2 Tx data for devices 4-11 **)
    Bus2_Devices_DLC3 AT %Q*: ARRAY[0..7] OF TxData; (** CAN Bus 2 DLC 3 commands **)
    Bus2_Devices_DLC4 AT %Q*: ARRAY[0..7] OF TxData; (** CAN Bus 2 DLC 4 commands **)
    Bus2_Devices_Rx AT %I*: ARRAY[0..7] OF RxData; (** CAN Bus 2 Rx data **)
    Bus3_Devices AT %Q*: ARRAY[0..7] OF TxData; (** CAN Bus 3 Tx data for devices 12-19 **)
    Bus3_Devices_DLC3 AT %Q*: ARRAY[0..7] OF TxData; (** CAN Bus 3 DLC 3 commands **)
    Bus3_Devices_DLC4 AT %Q*: ARRAY[0..7] OF TxData; (** CAN Bus 3 DLC 4 commands **)
    Bus3_Devices_Rx AT %I*: ARRAY[0..7] OF RxData; (** CAN Bus 3 Rx data **)
    CommFault: ARRAY[0..19] OF BOOL;      (** Communication fault per device **)
    CommTimeouts: ARRAY[0..19] OF INT;    (** Communication timeouts per device **)
    Current: ARRAY[0..19] OF BOOL;        (** Device mode Current: 0 = not in Current mode, 1 = Current mode **)
    CurrentScale: ARRAY[0..19] OF UINT;
    DataValid: ARRAY[0..19] OF BOOL;      (** Data freshness status **)
    DcOk: ARRAY[0..19] OF BOOL;           (** Secondary DD output voltage status: 0 = TOO LOW, 1 = NORMAL **)
    DeviceFlags: ARRAY[0..19] OF BYTE;    (** Device status bits **)
    DeviceSystemFlags: ARRAY[0..19] OF UINT;(** Device status bits **)
    Direction: ARRAY[0..19] OF BOOL;      (** Direction control **)
    Eeper: ARRAY[0..19] OF BOOL;          (** EEPROM data access error: 0 = normal, 1 = error **)
 	 EL2809_InputFlags: ARRAY[0..2] OF WORD;     (** 3 16-bit flags for EL2809 channels **)
    EL2798_InputFlags: BYTE;              (** 8-bit flags for EL2798 channels **)
    EL2809_Output AT %Q*: ARRAY[0..3,0..15] OF BOOL;  (** 16-channel output for EL2809 **)
    EL2798_Output AT %Q*: ARRAY[0..7] OF BOOL;   (** 8-channel output for EL2798 **)
    EL3174_Channel1_Value AT %I* : INT;           (** Raw analog value from EL3174 channel 1, 0-10V **)
    EL3174_Channel2_Value: INT;           (** Raw analog value from EL3174 channel 2, 0-10V **)
    EL3174_Channel3_Value: INT;           (** Raw analog value from EL3174 channel 3, 0-10V **)
    EL3174_Channel4_Value: INT;           (** Raw analog value from EL3174 channel 4, 0-10V **)
    EL3174_Channel1_Alarm: BOOL;          (** Yellow alarm from GT, channel 1, >2.5V **)
    EL3174_Channel2_Alarm: BOOL;          (** Alarm for channel 2, >2.5V, optional **)
    EL3174_Channel3_Alarm: BOOL;          (** Alarm for channel 3, >2.5V, optional **)
    EL3174_Channel4_Alarm: BOOL;          (** Alarm for channel 4, >2.5V, optional **)
    EStop: ARRAY[0..19] OF BOOL;          (** Emergency stop per device **)
    EthercatAlive: BOOL;                  (** EtherCAT communication status **)
    EthercatAliveFromMaster: BOOL;        (** EtherCAT master status **)
    EthercatAslaveStatus AT %I*: UINT;    (** EtherCAT slave status **)
    FanSpeed1: ARRAY[0..19] OF UINT;      (** Fan 1 speed, RPM **)
    FanSpeed2: ARRAY[0..19] OF UINT;      (** Fan 2 speed, RPM **)
    FanSpeedScale: ARRAY[0..19] OF UINT;
    FaultLevel: ARRAY[0..19] OF BYTE;     (** Fault severity **)
    FaultStatus: ARRAY[0..19] OF UINT;    (** Fault status code **)
    FirstRun: BOOL := TRUE;               (** Initial PLC startup flag **)
    GroupCapacity: ARRAY[0..3] OF UINT;   (** CBU capacity, watts **)
    GroupCurrentLimit: ARRAY[0..3] OF UINT; (** CBU current limit, 0-270A **)
    GroupDemand: ARRAY[0..3] OF UINT;     (** CBU demand, watts **)
    GroupMaster: ARRAY[0..3] OF INT;      (** CBU master device index **)
    GroupVoltageLimit: ARRAY[0..3] OF UINT; (** CBU voltage limit, 24-32V **)
	IoutSetpoint: ARRAY[0..19] OF REAL;  
    Iin: ARRAY[0..19] OF UINT;
    IinScale: ARRAY[0..19] OF UINT;
    InitialState: ARRAY[0..19] OF BOOL;   (** Device initialized status: 0 = initializing, 1 = not initializing **)
    Iout: ARRAY[0..19] OF UINT;           (** Output current, raw **)
    GroupMembership: ARRAY[0..19] OF INT;
    IoutSetRev: ARRAY[0..19] OF REAL;     (** Reverse current setpoint, F=0.01 **)
    LastUpdateTime: ARRAY[0..19] OF TIME; (** Last valid data timestamp **)
    MfrSerialPersistent: ARRAY[0..19] OF ARRAY[0..53] OF BYTE; (** Persistent storage for manufacturer serial data **)
    Ms: ARRAY[0..19] OF BOOL;             (** Parallel mode status: 0 = Slave, 1 = Master **)
    MorpheeCANCommFault: BOOL;            (** Morphee CAN fault **)
    MorpheeCommFault: BOOL;               (** Morphee communication fault **)
    MorpheeDoorPGSArea: BOOL;             (** Morphee door PGS area **)
    MorpheeECUFault: BOOL;                (** Morphee ECU fault **)
    MorpheeElectricalFault: BOOL;         (** Morphee electrical fault **)
    MorpheeEStop: BOOL;                   (** Morphee E-Stop **)
    MorpheeFireAlarm: BOOL;               (** Morphee fire alarm **)
    MorpheeGasPGSAlarm: BOOL;             (** Morphee gas PGS alarm **)
    MorpheeMCUFault: BOOL;                (** Morphee MCU fault **)
    MorpheeScavengeFanFault: BOOL;        (** Morphee scavenge fan fault **)
    MorpheeWatchdogFault: BOOL;           (** Morphee watchdog fault **)
    NumericInput AT %I*: ARRAY[0..239] OF WORD; (** EtherCAT input data **)
    (* Temporary test inputs for groups: 4 groups x 7 inputs = 28 indices *)
    UseTempGroupInputs : BOOL := FALSE;        (** When TRUE, EthercatManager will read group inputs from TempGroupInput instead of NumericInput **)
    TempGroupInput : ARRAY[0..27] OF WORD;     (** Temporary group inputs mapping for testing; indexes 0..27 map to group base 10..37 **) 
    UseTempBus1Direct : BOOL := FALSE;         (** When TRUE, EthercatManager will read Bus1 device inputs from TempBus1* arrays instead of NumericInput **)
    TempBus1VoutSetpoint : ARRAY[0..3] OF WORD;(** Temporary Bus1 voltage setpoints, V*100 **)
    TempBus1IoutSetpoint : ARRAY[0..3] OF WORD;(** Temporary Bus1 current setpoints, A*100 **)
    TempBus1Flags : ARRAY[0..3] OF WORD;       (** Temporary Bus1 flags, same bit mapping as device flags **)
    TempBus1VoutSetMin : ARRAY[0..3] OF WORD;  (** Temporary Bus1 min voltage, V*100 **)
    TempBus1VoutSetMax : ARRAY[0..3] OF WORD;  (** Temporary Bus1 max voltage, V*100 **)
    TempBus1IoutSetMin : ARRAY[0..3] OF WORD;  (** Temporary Bus1 min current, A*100 **)
    TempBus1IoutSetMax : ARRAY[0..3] OF WORD;  (** Temporary Bus1 max current, A*100 **)
    NumericOutput AT %Q*: ARRAY[0..120] OF DWORD; (** EtherCAT output data **)
    OperationOn: ARRAY[0..19] OF BOOL;    (** Device operation status **)
    OrangeStop: ARRAY[0..19] OF BOOL;     (** Orange-level stop **)
    OutputOn: ARRAY[0..19] OF BOOL;       (** Output enabled status **)
    PfcOk: ARRAY[0..19] OF BOOL;          (** Primary PFC status: 0 = OFF/abnormal, 1 = ON normally **)
    PollingPaused: ARRAY[0..19] OF BOOL;  (** CAN polling pause **)
    PollingPauseTimeout: ARRAY[0..19] OF TON; (** Timeout for polling pause **)
    PollingPauseStartTime: ARRAY[0..19] OF TIME; (** Start time of polling pause **)
    ReadCommandIndex: ARRAY[0..19] OF INT; (** CAN read command index **)
    RecoveryPending: ARRAY[0..19] OF BOOL; (** Fault recovery pending **)
    RedStop: ARRAY[0..19] OF BOOL;        (** Red-level stop **)
    RemoteMasterAlive: BOOL;              (** Remote master status **)
    SafetyCANCommFault: BOOL;             (** Safety CAN fault **)
    SafetyDoorPGSArea: BOOL;              (** Safety door PGS area **)
    SafetyECUFault: BOOL;                 (** Safety ECU fault **)
    SafetyElectricalFault: BOOL;          (** Safety electrical fault **)
    SafetyEStop: INT;                     (** System E-Stop counter **)
    SafetyFireAlarm: BOOL;                (** Safety fire alarm **)
    SafetyGasPGSAlarm: BOOL;              (** Safety gas PGS alarm **)
    SafetyMCUFault: BOOL;                 (** Safety MCU fault **)
    SafetyOK: ARRAY[0..19] OF BOOL;       (** Device safe to operate **)
    SafetyRecovery: BOOL;                 (** Fault recovery status **)
    SafetyShutdown: ARRAY[0..19] OF BOOL; (** Device in safety shutdown **)
    Standby: ARRAY[0..19] OF BOOL;        (** Device mode Standby: 0 = not in Standby mode, 1 = Standby mode **)
    SuccessCounts: ARRAY[0..19] OF INT;   (** Successful polls per device **)
    SystemAlarms: UINT;                   (** System alarms bitfield **)
    SystemFlags: BYTE;                    (** System flags, bit 0 = maintenance **)
    SystemState: BYTE;                    (** System state: 0=normal, 1=orange, 2=red, 3=EStop **)
    TempScale: ARRAY[0..19] OF UINT;
    Temperature: ARRAY[0..19] OF UINT;    (** Device temperature, raw **)
    TemperatureFaultHigh AT %I*: ARRAY[0..19] OF BOOL; (** Hard-wired high temp fault **)
    Vin: ARRAY[0..19] OF UINT;            (** Input voltage, raw **)
    VinScale: ARRAY[0..19] OF UINT;
    Voltage: ARRAY[0..19] OF BOOL;        (** Device mode Voltage: 0 = not in Voltage mode, 1 = Voltage mode **)
    Vout: ARRAY[0..19] OF UINT;           (** Output voltage, raw **)
    VoutScale: ARRAY[0..19] OF UINT;
    VoutSetpoint: ARRAY[0..19] OF REAL;   (** Forward voltage setpoint, F=0.1 **)
    VoutSetRev: ARRAY[0..19] OF REAL;     (** Reverse voltage setpoint, F=0.01 **)
END_VAR]]></Declaration>
  </GVL>
</TcPlcObject>