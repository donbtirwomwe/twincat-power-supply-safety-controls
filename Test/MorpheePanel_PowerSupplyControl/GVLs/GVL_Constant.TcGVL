<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <GVL Name="GVL_Constant" Id="{7718ce57-0681-4809-ba8b-af8e8a7d9d96}">
    <Declaration><![CDATA[VAR_GLOBAL CONSTANT
  CMD_BIDIRECTIONAL_CONFIG : UINT := 16#0140; (* R/W, 1 byte: Bidirectional config, DLC 3 *)
  CMD_DIRECTION_CTRL : UINT := 16#0100;     (* R/W, 1 byte: 00h=AC-to-DC, 01h=DC-to-AC, DLC 3 *)
  CMD_FAULT_STATUS : UINT := 16#0040;   (* R, 2 bytes: Fault status *)
  CMD_IOUT_SET : UINT := 16#0030;       (* R/W, 2 bytes: Current setpoint, DLC 4 *)
  CMD_MFR_DATE_B0B5 : UINT := 16#0086;      (* R/W, 6 bytes: Date *)
  CMD_MFR_ID_B0B5 : UINT := 16#0080;        (* R, 6 bytes: Manufacturer ID, bytes 0-5 *)
  CMD_MFR_ID_B6B11 : UINT := 16#0081;       (* R, 6 bytes: Manufacturer ID, bytes 6-11 *)
  CMD_MFR_LOCATION_B0B2 : UINT := 16#0085;  (* R/W, 3 bytes: Location *)
  CMD_MFR_MODEL_B0B5 : UINT := 16#0082;     (* R, 6 bytes: Model, bytes 0-5 *)
  CMD_MFR_MODEL_B6B11 : UINT := 16#0083;    (* R, 6 bytes: Model, bytes 6-11 *)
  CMD_MFR_REVISION_B0B5 : UINT := 16#0084;  (* R, 6 bytes: Revision, bytes 0-5 *)
  CMD_MFR_SERIAL_B0B5 : UINT := 16#0087;    (* R/W, 6 bytes: Serial number, bytes 0-5 *)
  CMD_MFR_SERIAL_B6B11 : UINT := 16#0088;   (* R/W, 6 bytes: Serial number, bytes 6-11 *)
  CMD_OPERATION : UINT := 16#0000;      (* R/W, 1 byte: 00h=OFF, 01h=ON, DLC 3 *)
  CMD_READ_FAN_SPEED1 : UINT := 16#0071;    (* R, 2 bytes: Fan 1 speed *)
  CMD_READ_FAN_SPEED2 : UINT := 16#0072;    (* R, 2 bytes: Fan 2 speed *)
  CMD_READ_IOUT : UINT := 16#0061;      (* R, 2 bytes: Output current, F=0.01 or 0.1 *)
  CMD_READ_TEMPERATURE_1 : UINT := 16#0062; (* R, 2 bytes: Temperature, F=0.1 *)
  CMD_READ_VIN : UINT := 16#0050;       (* R, 2 bytes: Input voltage, F=0.1 *)
  CMD_READ_VOUT : UINT := 16#0060;      (* R, 2 bytes: Output voltage, F=0.01 or 0.1 *)
  CMD_REVERSE_IOUT_SET : UINT := 16#0130;   (* R/W, 2 bytes: Reverse current setpoint, F=0.01, DLC 4 *)
  CMD_REVERSE_VOUT_SET : UINT := 16#0120;   (* R/W, 2 bytes: Reverse voltage setpoint, F=0.01, DLC 4 *)
  CMD_SCALING_FACTOR : UINT := 16#00C0;     (* R, 2 bytes: scaling factors (BIC models) *)
  CMD_SYSTEM_STATUS : UINT := 16#00C1;      (* R, 2 bytes: system status bits (M/S, DC_OK, PFC_OK, etc.) *)
  CMD_SYSTEM_CONFIG : UINT := 16#00C2;      (* R/W, 2 bytes: System configuration, DLC 4 *)
  CMD_VOUT_SET : UINT := 16#0020;       (* R/W, 2 bytes: Voltage setpoint, DLC 4 *)
  ESTOPTIME : TIME := T#10s;            (* Delay before E-Stop disables outputs *)
  HEARTBEATTIMEOUT : TIME := T#45ms;    (* Timeout for Morphee heartbeat *)
  IoutMax : UINT := 75;               (* Maximum current per BIC-2200 device, 2200A *)
  MAX_CURRENT : UINT := 270;            (* Maximum allowable current limit, 270A, unscaled, per CBU group *)
  MAX_VOLTAGE : UINT := 32;             (* Maximum allowable voltage limit, 32V, unscaled *)
  MAXCOMMSTALE : TIME := T#2s;          (* Threshold for stale communication data *)
  MAXCOMMTIMEOUT : UINT := 200;         (* Max comm timeouts before fault, 2s at 10ms cycle *)
  MfrCommands : ARRAY[0..8] OF UINT := [CMD_MFR_ID_B0B5, CMD_MFR_ID_B6B11, CMD_MFR_MODEL_B0B5,
                                        CMD_MFR_MODEL_B6B11, CMD_MFR_REVISION_B0B5, CMD_MFR_LOCATION_B0B2,
                                        CMD_MFR_DATE_B0B5, CMD_MFR_SERIAL_B0B5, CMD_MFR_SERIAL_B6B11]; (* Commands for Morphee initialization *)
  MIN_CURRENT : UINT := 0;              (* Minimum allowable current limit, 0A, unscaled *)
  MIN_VOLTAGE : UINT := 24;             (* Minimum allowable voltage limit, 24V, unscaled *)
  MINSUCCESSCLEAR : UINT := 3;          (* Minimum successful polls to clear fault *)
  MODE_CURRENT_FWD : BYTE := 1;         (* Current control, forward direction *)
  MODE_CURRENT_REV : BYTE := 3;         (* Current control, reverse direction *)
  MODE_STANDBY : BYTE := 0;             (* Standby mode *)
  MODE_VOLTAGE_FWD : BYTE := 2;         (* Voltage control, forward direction *)
  MODE_VOLTAGE_REV : BYTE := 4;         (* Voltage control, reverse direction *)
  OFFRAMP : TIME := T#10s;              (* Duration for OFF ramp-down *)
  ORANGESTOPTIME : TIME := T#3m;        (* Delay before Orange Stop disables outputs *)
  REDSTOPTIME : TIME := T#1m;           (* Delay before Red Stop disables outputs *)
  REMOTETIMEOUT : TIME := T#2s;         (* Timeout for RemoteMasterAlive *)
  SHUTDOWNRAMP : TIME := T#60s;         (* Duration for shutdown ramp-down *)
END_VAR]]></Declaration>
  </GVL>
</TcPlcObject>