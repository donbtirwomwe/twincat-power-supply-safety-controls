    <LineIds Name="EthercatManager.UpdateOutputs">
      <LineId Id="9533" Count="25" />
      <LineId Id="9880" Count="0" />
      <LineId Id="9559" Count="270" />
      <LineId Id="9883" Count="2" />
      <LineId Id="9882" Count="0" />
      <LineId Id="9830" Count="5" />
      <LineId Id="9881" Count="0" />
      <LineId Id="9886" Count="2" />
      <LineId Id="9836" Count="7" />
