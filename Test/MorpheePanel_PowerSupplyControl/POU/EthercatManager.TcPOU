<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <POU Name="EthercatManager" Id="{f73e9df5-d22b-4027-8eaf-ab5cb0520b6c}" SpecialFunc="None">
    <Declaration><![CDATA[
FUNCTION_BLOCK EthercatManager
VAR
  IsInitPhase : BOOL := FALSE;               (* TRUE during initialization phase *)
  InitCycle : INT := 0;                      (* Current initialization cycle, 0-5 *)
  LastVoutSetpoint : ARRAY[0..19] OF UINT;   (* Last voltage setpoint sent *)
  LastIoutSetpoint : ARRAY[0..19] OF UINT;   (* Last current setpoint sent *)
  LastOutputOn : ARRAY[0..19] OF BOOL;       (* Last output enabled state *)
  LastOperationOn : ARRAY[0..19] OF BOOL;    (* Last operation state *)
  LastDirection : ARRAY[0..19] OF BOOL;      (* Last direction state *)
  fbDeviceManager : DeviceManager;           (* Device manager instance *)
  DataRefreshRequired : BOOL;                (* Flag for data refresh required *)
  RefreshTableRequired : BOOL;               (* Flag for table refresh required *)
  InitTimeout : TON;                         (* 10s timeout for init cycles *)
  LastMorpheeSignal : UINT;                  (* Track last Morphee signal *)
  VoutSetMin : ARRAY[0..19] OF UINT;		 (* Vout min limit *)
  VoutSetMax : ARRAY[0..19] OF UINT; 		 (* Vout max limit *)
  IoutSetMin : ARRAY[0..19] OF UINT; 		 (* Iout min limit *)
  IoutSetMax : ARRAY[0..19] OF UINT; 		 (* Iout max limit *)
  CanCtrlConfigured : ARRAY[0..19] OF BOOL; (* True after SYSTEM_CONFIG(0x00C2)=0x0003 is sent successfully *)
  BidirAutoConfigured : ARRAY[0..19] OF BOOL; (* True after BIDIRECTIONAL_CONFIG(0x0140)=0x00 is sent successfully *)
  LastCommFault : ARRAY[0..19] OF BOOL;     (* Latch previous CommFault state to detect rising edge *)
  FaultResetRequestPrev : BOOL;             (* Previous value of manual fault-reset request bit *)
  FaultResetState : ARRAY[0..19] OF BYTE;   (* 0=idle, 1=send OPERATION OFF, 2=delay+send OPERATION ON *)
  FaultResetCounter : ARRAY[0..19] OF UINT; (* Counter for staged reset timing per device *)
  commandData : UINT;                        (** Data to use for command **)
  LastCommandSentTime : ARRAY[0..19] OF TIME; (* Last successful write timestamp per device *)
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* Comment Section: GVL.NumericInput and GVL.NumericOutput Mapping *)
(* Purpose: This section provides a detailed reference for the GVL.NumericInput and GVL.NumericOutput *)
(* mappings used by the EthercatManager function block, including system inputs, group inputs, *)
(* device inputs, and output structures. All indices are carefully allocated to ensure no overlap *)
(* and to support the system's parallel configuration, maintenance mode, and group operation. *)

(* GVL.NumericInput Mapping *)
(* Overview: GVL.NumericInput stores system-wide inputs, group inputs, and device inputs for the *)
(* 20 power supply units (devices 0-19) and 4 groups (LVLA1-LVLA4). The allocation starts system *)
(* inputs at index 0, with group and device inputs starting at index 10. Each device and group *)
(* has 7 inputs to support setpoints, flags, and limits. *)

(* 0-4: System-Level Inputs and Reserves (5 indices) *)
(*   0: GVL.SystemAlarms (WORD to UINT) *)
(*      - Stores system-wide alarms, processed in ProcessInputs *)
(*   1: System Flags (WORD) *)
(*      - Bit 0 (16#0001): GVL.SystemFlags (includes maintenanceMode, set in ProcessInputs) *)
(*        - maintenanceMode = TRUE: Disables groups, uses individual device inputs *)
(*        - maintenanceMode = FALSE: Enables groups, master uses group inputs *)
(*      - Bit 1 (16#0002): GVL.EthercatAliveFromMaster (EtherCAT master status) *)
(*      - Bit 2 (16#0004): GVL.RemoteMasterAlive (Remote master status) *)
(*      - Bit 8 (16#0100): Manual BIC reset request (force OPERATION OFF->ON sequence) *)
(*      - Other bits 3-15: Unallocated (reserved for future flags) *)
(*   2: Morphee Initialization Signal (DWORD to UINT, processed in UpdateOutputs) *)
(*      - Values 1-5: Initialization cycle *)
(*      - Value 100: Complete initialization *)
(*   3-4: Reserved *)
(*      - Unallocated indices for future system-wide inputs *)
(* 5  EL2809 rack 1 slot 1
-9: Unallocated *)
(*      - Reserved for future system expansion *)
(* 10-37: Group Inputs (4 groups x 7 inputs = 28 indices) *)
(*   - Each group (LVLA1-LVLA4) has 7 inputs, treating the group as a single device in normal mode *)
(*   - For groupIdx = 0 TO 3, baseIdx = 10 + (groupIdx * 7): *)
(*     baseIdx: GroupVoutSetpoint (Voltage setpoint for group, applied to master) *)
(*     baseIdx + 1: GroupIoutSetpoint (Current setpoint for master, internally distributed) *)
(*     baseIdx + 2: Group Flags (WORD, similar to device flags) *)
(*       - Bit 0 (16#0001): GroupDirection (Forward/reverse, assumed) *)
(*       - Bit 1 (16#0002): GroupOperationOn (Operation active, assumed) *)
(*       - Bits 2-3 (16#000C): GroupDeviceMode (0-3, assumed) *)
(*       - Bit 7 (16#0080): GroupEStop (Assumed) *)
(*     baseIdx + 3: GroupVoutSetMin (Minimum voltage limit for master) *)
(*     baseIdx + 4: GroupVoutSetMax (Maximum voltage limit for master) *)
(*     baseIdx + 5: GroupIoutSetMin (Minimum current limit for master) *)
(*     baseIdx + 6: GroupIoutSetMax (Maximum current limit, constrained by GVL.GroupCapacity) *)
(*   - Group Index Breakdown: *)
(*     LVLA1 (groupIdx = 0): 10-16 *)
(*     LVLA2 (groupIdx = 1): 17-23 *)
(*     LVLA3 (groupIdx = 2): 24-30 *)
(*     LVLA4 (groupIdx = 3): 31-37 *)
(*   - Note: GroupIoutSetMax must not exceed GVL.GroupCapacity (set by GroupManager based *)
(*     on healthy units, e.g., opCount * 25). Limits are applied in ReadLimits method. *)
(* 38-177: Device Inputs (20 devices x 7 inputs = 140 indices) *)
(*   - Each device (0-19) has 7 inputs for setpoints, flags, and limits *)
(*   - For devIdx = 0 TO 19, baseIdx = 38 + (devIdx * 7): *)
(*     baseIdx: VoutSetpoint (Voltage setpoint, applied to device in maintenance mode *)
(*              or master in normal mode) *)
(*     baseIdx + 1: IoutSetpoint (Current setpoint, applied to device or master) *)
(*     baseIdx + 2: Flags (WORD, processed in ProcessInputs) *)
(*       - Bit 0 (16#0001): Direction (Forward/reverse) *)
(*       - Bit 1 (16#0002): OperationOn (Operation active) *)
(*       - Bits 2-3 (16#000C): DeviceMode (0-3, e.g., 1 = current mode, 2 = voltage mode) *)
(*       - Bit 4 (16#0010): OutputOn (Device enabled) *)
(*       - Bit 5 (16#0020): OrangeStop *)
(*       - Bit 6 (16#0040): RedStop *)
(*       - Bit 7 (16#0080): EStop *)
(*     baseIdx + 3: VoutSetMin (Minimum voltage limit) *)
(*     baseIdx + 4: VoutSetMax (Maximum voltage limit) *)
(*     baseIdx + 5: IoutSetMin (Minimum current limit) *)
(*     baseIdx + 6: IoutSetMax (Maximum current limit) *)
(*   - Device Index Breakdown (examples): *)
(*     devIdx = 0: 38-44 *)
(*     devIdx = 4: 66-72 *)
(*     devIdx = 19: 171-177 *)
(*   - Note: In normal mode, master device's setpoints/limits are overridden by group *)
(*     inputs (handled in ReadLimits). In maintenance mode, each device uses its own inputs. *)
(* 178+: Unallocated *)
(*      - Available for future expansion *)

(* GVL.NumericOutput Mapping *)
(* Overview: GVL.NumericOutput stores device status, system alarms, group master indices, *)
(* and group capacities. In initialization mode, it handles manufacturer serial data. *)
(* 0-99: Device Outputs (20 devices x 5 outputs = 100 indices) *)
(*   - For devIdx = 0 TO 19, baseIdx = devIdx * 5: *)
(*     baseIdx: Vin (high 16 bits), Vout (low 16 bits) *)
(*     baseIdx + 1: Iout (high), Temperature (low) *)
(*     baseIdx + 2: FanSpeed1 (high), FanSpeed2 (low) *)
(*     baseIdx + 3: FaultStatus (high 16 bits), Status Flags (low bits) *)

(*       - Bit 0: OperationOn *)
(*       - Bit 1: Direction *)
(*       - Bits 2: current*)
(*       - Bits 3: current*)
(*       - Bit 4: OutputOn *)
(*       - Bit 5: OrangeStop *)
(*       - Bit 6: RedStop *)
(*       - Bit 7: EStop *)
(*       - Bit 8: TemperatureFaultHigh *)
(*     baseIdx + 4: FanSpeed1 (high 16 bits) *)
(*   - Example: *)
(*     devIdx = 0: 0-4 *)
(*     devIdx = 4: 20-24 *)
(*     devIdx = 19: 95-99 *)
(* 100: systemAlarms (DWORD, system-wide alarms) *)
(* 101: System Flags (WORD) *)
(*   - Bit 0: GVL.SystemFlags *)
(*   - Bit 1: RefreshTableRequired *)
(*   - Bit 2: GVL.EthercatAliveFromMaster *)
(*   - Bit 3: GVL.RemoteMasterAlive *)
(*   - Bit 4: watchDog (toggled per cycle) *)
(*   - Bit 5: DataRefreshRequired *)
(*   - Bit 6: EL3174_Channel1_Alarm *)
(*   - Bit 7: EL3174_Channel2_Alarm *)
(*   - Bit 8: EL3174_Channel3_Alarm *)
(*   - Bit 9: EL3174_Channel4_Alarm *)
(* 102: GroupMaster[0] (high 16 bits), GroupMaster[1] (low 16 bits) *)
(* 103: GroupMaster[2] (high), GroupMaster[3] (low) *)
(* 104-107: Group absolute voltage limits (x100 V) for operator UI bounds *)
(*   - 104: LVLA1 (devices 4-7), 105: LVLA2, 106: LVLA3, 107: LVLA4 *)
(*   - High 16 bits: Absolute VoutSetMin (MIN_VOLTAGE * 100) *)
(*   - Low 16 bits:  Absolute VoutSetMax (MAX_VOLTAGE * 100) *)
(* 108-111: GVL.GroupCapacity (UINT to DWORD, capacity per group) *)
(*   - 108: LVLA1 *)
(*   - 109: LVLA2 *)
(*   - 110: LVLA3 *)
(*   - 111: LVLA4 *)
(*   - Capacity based on healthy units (opCount * 25), influences group limits *)
(* 112-115: Group absolute current limits (x10 A) for operator UI bounds *)
(*   - 112: LVLA1 (devices 4-7), 113: LVLA2, 114: LVLA3, 115: LVLA4 *)
(*   - High 16 bits: Forward absolute Iout max (active_count * BIC24_IOUT_MAX_FWD * 10) *)
(*   - Low 16 bits:  Reverse absolute Iout max (active_count * BIC24_IOUT_MAX_REV * 10) *)
(* 0-119 (Initialization Mode): Manufacturer Serial Data *)
(*   - Used for MfrSerialPersistent during initialization cycles *)
(*   - Index calculation: idx = (devIdx * 27) + (i * 3) + j *)
(*   - cmdId (16#80 + i) and serial data packed into WORD *)
]]></ST>
    </Implementation>
    <Method Name="ApplyCommands" Id="{ee2cc573-91f9-4349-9f7c-e0af36fc135f}">
      <Declaration><![CDATA[METHOD ApplyCommands : BOOL
VAR_INPUT
  devIdx : INT;                            (** Device index **)
  commandCode : UINT;                      (** Command code **)
  data : UINT;                             (** Command data value **)
END_VAR
VAR
  nowTime : TIME;
END_VAR
       
       ]]></Declaration>
      <Implementation>
        <ST><![CDATA[(** Send CAN commands with polling paused, respecting OutputOn **)
IF devIdx >= 0 AND devIdx <= 19 THEN
  (* Re-arm configuration only when CommFault rises; otherwise avoid blocking all writes forever. *)
  IF GVL.CommFault[devIdx] AND NOT LastCommFault[devIdx] THEN
    CanCtrlConfigured[devIdx] := FALSE;
    BidirAutoConfigured[devIdx] := FALSE;
  END_IF;
  LastCommFault[devIdx] := GVL.CommFault[devIdx];

    (* Ensure CAN control mode is enabled for BIC devices (4..19) only.
      Bus1 DPU devices (0..3) use a different protocol model and should not receive SYSTEM_CONFIG here. *)
  IF (commandCode = 16#0000 OR commandCode = 16#0020 OR commandCode = 16#0030 OR commandCode = 16#0120 OR commandCode = 16#0130)
      AND devIdx >= 4 AND NOT CanCtrlConfigured[devIdx] THEN
    IF fbDeviceManager.WriteDLC4(devIdx, GVL_Constant.CMD_SYSTEM_CONFIG, 16#0003) THEN
      CanCtrlConfigured[devIdx] := TRUE;
    END_IF;
    ApplyCommands := FALSE;
    RETURN;
  END_IF;

  (* BIDIRECTIONAL_CONFIG (0x0140) is polled once during init in DeviceManager.
     Do not send it via WriteDLC here. *)
  IF (commandCode = 16#0000 OR commandCode = 16#0020 OR commandCode = 16#0030 OR commandCode = 16#0120 OR commandCode = 16#0130)
      AND devIdx >= 4 AND CanCtrlConfigured[devIdx] AND NOT BidirAutoConfigured[devIdx] THEN
    BidirAutoConfigured[devIdx] := TRUE;
    ApplyCommands := FALSE;
    RETURN;
  END_IF;

  (* DPU manual requires >=50 ms spacing between commands. Apply per-device write pacing globally for safety. *)
  nowTime := TIME();
  IF LastCommandSentTime[devIdx] <> T#0MS AND
     ((devIdx <= 3 AND (nowTime - LastCommandSentTime[devIdx]) < T#50MS) OR
      (devIdx >= 4 AND (nowTime - LastCommandSentTime[devIdx]) < T#10MS)) THEN
    ApplyCommands := FALSE;
    RETURN;
  END_IF;

  (** Determine command data and clear setpoints based on OutputOn/OperationOn **)
  IF devIdx <= 3
     AND (commandCode = 16#0020 OR commandCode = 16#0030 OR commandCode = 16#0120 OR commandCode = 16#0130)
     AND (NOT GVL.OutputOn[devIdx] OR NOT GVL.OperationOn[devIdx])
     AND data <> 0 THEN
    (* DPU setpoint writes are gated: require both OutputOn and OperationOn. *)
    ApplyCommands := FALSE;
    RETURN;
  END_IF;

  IF devIdx >= 4 OR GVL.OutputOn[devIdx] OR commandCode = 16#0000 OR commandCode = 16#0100 THEN
    commandData := data; (** Use provided data for enabled output or non-setpoint commands **)
  ELSE
    commandData := 0; (** Output is off: send zero, but keep requested setpoints latched for retry when output turns on **)
  END_IF;

  (** Proceed with command **)
  GVL.PollingPaused[devIdx] := TRUE; (** Pause polling for this device **)
  GVL.PollingPauseStartTime[devIdx] := TIME(); (** Record pause start time **)
  GVL.PollingPauseTimeout[devIdx](IN := TRUE, PT := T#100MS); (** Start 100ms timeout **)
  CASE commandCode OF
    16#0000: (** CMD_OPERATION **)
      ApplyCommands := fbDeviceManager.WriteDLC3(devIdx, GVL_Constant.CMD_OPERATION, UINT_TO_BYTE(commandData));
    16#0100: (** CMD_DIRECTION_CTRL **)
      ApplyCommands := fbDeviceManager.WriteDLC3(devIdx, GVL_Constant.CMD_DIRECTION_CTRL, UINT_TO_BYTE(commandData));
    16#0020: (** CMD_VOUT_SET **)
      ApplyCommands := fbDeviceManager.WriteDLC4(devIdx, GVL_Constant.CMD_VOUT_SET, commandData);
    16#0030: (** CMD_IOUT_SET **)
      ApplyCommands := fbDeviceManager.WriteDLC4(devIdx, GVL_Constant.CMD_IOUT_SET, commandData);
    16#0120: (** CMD_REVERSE_VOUT_SET **)
      ApplyCommands := fbDeviceManager.WriteDLC4(devIdx, GVL_Constant.CMD_REVERSE_VOUT_SET, commandData);
    16#0130: (** CMD_REVERSE_IOUT_SET **)
      ApplyCommands := fbDeviceManager.WriteDLC4(devIdx, GVL_Constant.CMD_REVERSE_IOUT_SET, commandData);
    ELSE
      ApplyCommands := FALSE; (** Invalid command code **)
      GVL.PollingPaused[devIdx] := FALSE; (** Resume polling on invalid command **)
      GVL.PollingPauseTimeout[devIdx](IN := FALSE); (** Stop timeout **)
  END_CASE;
  IF ApplyCommands THEN
    LastCommandSentTime[devIdx] := nowTime;
    (* Force immediate feedback polling after setpoint writes. ReadCommands index: 1=VOUT, 2=IOUT *)
    CASE commandCode OF
      16#0020, 16#0120:
        GVL.ReadCommandIndex[devIdx] := 1;
      16#0030, 16#0130:
        GVL.ReadCommandIndex[devIdx] := 2;
    END_CASE;

    GVL.PollingPaused[devIdx] := FALSE; (** Resume polling after successful write **)
    GVL.PollingPauseTimeout[devIdx](IN := FALSE); (** Stop timeout **)
  ELSE
    GVL.PollingPaused[devIdx] := FALSE; (** Do not hold polling off after a failed write attempt **)
    GVL.PollingPauseTimeout[devIdx](IN := FALSE); (** Stop timeout when write did not go out **)
  END_IF;
ELSE
  ApplyCommands := FALSE; (** Invalid device index **)
END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="ProcessInputs" Id="{b2c3d4e5-2345-6789-0123-456789abcdef}">
      <Declaration><![CDATA[METHOD ProcessInputs
VAR
  devIdx : INT;                            (** Device index **)
  baseIdx : INT;                           (** Base index for device inputs **)
  flags : WORD;                            (** Device-specific input flags **)
  systemFlags : WORD;                      (** System flags **)
  safetyOK : BOOL;                         (** Safety status **)
  groupIdx : INT;                          (** Group index **)
  memberIdx : INT;                         (** Member device index **)
  masterIdx : INT;                         (** Master device index **)
  groupBase : INT;                         (** Base index for group devices **)
  maintenanceMode : BOOL;                  (** Maintenance mode status **)
  isGroupMaster : BOOL;                    (** Group master flag **)
  clampedVout : UINT;                      (** Clamped voltage setpoint **)
  clampedIout : UINT;                      (** Clamped current setpoint **)
  i : INT;                                 (** Loop index for channel mapping **)
  factorNibble : UINT;                     (** Factor nibble from scaling-factor fields **)
  setpointIout : REAL;                     (** Clamped Iout setpoint before scaling **)
  setpointVout : REAL;                     (** Clamped Vout setpoint before scaling **)
	tempBase : INT;                           (** Temp: offset into TempGroupInput array **)
  isGroupedMaster : BOOL;                   (** TRUE when device is valid group master **)
  usePerDeviceInputs : BOOL;                (** TRUE when this device should consume per-device NumericInput slots **)
  groupVoutRaw : UINT;                      (** Group voltage setpoint in x100 format **)
  groupIoutRawTotal : UINT;                 (** Group total current setpoint in x100 format **)
  groupIoutRawPerDevice : UINT;             (** Group split current per active device in x100 format **)
  groupOutputRequest : BOOL;                (** Group requested OutputOn state from flags **)
  activeInGroup : UINT;                     (** Number of active devices in current group **)
  groupIoutRawLimitPerDevice : UINT;        (** Direction-dependent per-device current cap in x100 **)
  groupIoutLimitInput : UINT;               (** Group Iout max limit input before capacity constraint **)
  desiredReverse : BOOL;                    (** Per-cycle requested direction bit from active control flags **)
  groupInputBaseIdx : INT;                  (** Canonical NumericInput base index for grouped BIC control **)
  requestedOutputOn : BOOL;                 (** OutputOn request bit from active flags **)
	resetRequest : BOOL;                      (** Manual fault reset request from EtherCAT system flags bit 8 **)
	morpheeUseIndividualBicControl : BOOL;    (** Bit 9 in system flags requests individual BIC control from Morphee **)
	j: INT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[

(** Comment Section: GVL.NumericInput Mapping for ProcessInputs **)
(** This method processes system, group, and device inputs from GVL.NumericInput, setting **)
(** setpoints, flags, and maintenance mode. In normal mode (maintenanceMode = FALSE), **)
(** group flags (Direction, OperationOn, OutputOn) are set for all devices in the group **)
(** (4-19), but DeviceMode (Voltage, Current, Standby) and setpoints (VoutSetpoint, **)
(** IoutSetpoint) are set only for the group master. In maintenance mode or for devices **)
(** 0-3, all flags and setpoints are set per device. Group limits are applied to all **)
(** devices in the group, with IoutSetMax constrained by the minimum of GroupIoutSetMax **)
(** and GVL.GroupCapacity (set by GroupManager.UpdateGroupCapacity using input voltage **)
(** feedback, GVL.Vin > 100). GroupMaster is updated by GroupManager.UpdateGroupMasters **)
(** using input voltage feedback. Groups: 0=4-7, 1=8-11, 2=12-15, 3=16-19. **)
(** Flags for groups and devices use identical bit assignments. **)

(** GVL.NumericInput Mapping **)
(** 0-4: System-Level Inputs **)
(**   0: GVL.SystemAlarms (WORD to UINT) **)
(**      - System-wide alarms, read into GVL.SystemAlarms **)
(**   1: System Flags (WORD) **)
(**      - Bit 0 (16#0001): GVL.SystemFlags (sets maintenanceMode) **)
(**      - Bit 1 (16#0002): GVL.EthercatAliveFromMaster **)
(**      - Bit 2 (16#0004): GVL.RemoteMasterAlive **)
(**   2: Morphee Initialization Signal **)
(**      - Used in UpdateOutputs, not processed here **)
(**   3-4: Reserved **)
(** 5-9: Unallocated **)
(** 10-37: Group Inputs (4 groups x 7 inputs) **)
(**   - For groupIdx = 0 TO 3, baseIdx = 10 + (groupIdx * 7): **)
(**     baseIdx: GroupVoutSetpoint **)
(**     baseIdx + 1: GroupIoutSetpoint **)
(**     baseIdx + 2: Group Flags **)
(**       - Bit 0 (16#0001): Direction **)
(**       - Bit 1 (16#0002): OperationOn **)
(**       - Bit 2 (16#0004): DeviceMode Current **)
(**       - Bit 3 (16#0008): DeviceMode Voltage **)
(**       - Bit 4 (16#0010): OutputOn **)
(**     baseIdx + 3: GroupVoutSetMin **)
(**     baseIdx + 4: GroupVoutSetMax **)
(**     baseIdx + 5: GroupIoutSetMin **)
(**     baseIdx + 6: GroupIoutSetMax **)
(**   - GroupVoutSetpoint, GroupIoutSetpoint, and DeviceMode applied to master device only in normal mode **)
(**   - GroupVoutSetMin, GroupVoutSetMax, GroupIoutSetMin, GroupIoutSetMax applied to all devices in group **)
(**   - Group Flags (Direction, OperationOn, OutputOn) set for all devices in group in normal mode **)
(** 38-177: Device Inputs (20 devices x 7 inputs) **)
(**   - For devIdx = 0 TO 19, baseIdx = 38 + (devIdx * 7): **)
(**     baseIdx: VoutSetpoint (Read here) **)
(**     baseIdx + 1: IoutSetpoint (Read here) **)
(**     baseIdx + 2: Flags (Read here) **)
(**       - Bit 0 (16#0001): Direction **)
(**       - Bit 1 (16#0002): OperationOn **)
(**       - Bit 2 (16#0004): DeviceMode Current **)
(**       - Bit 3 (16#0008): DeviceMode Voltage **)
(**       - Bit 4 (16#0010): OutputOn **)
(**       - Bit 5 (16#0020): OrangeStop **)
(**       - Bit 6 (16#0040): RedStop **)
(**       - Bit 7 (16#0080): EStop **)
(**     baseIdx + 3: VoutSetMin (Set in ReadLimits) **)
(**     baseIdx + 4: VoutSetMax **)
(**     baseIdx + 5: IoutSetMin **)
(**     baseIdx + 6: IoutSetMax **)
(** 178+: Unallocated **)

(** Read limits first **)
THIS^.ReadLimits();

(** Read system alarms **)
GVL.SystemAlarms := GVL.NumericInput[0]; (** Index 0: System alarms **)

(** Read system flags **)
systemFlags := GVL.NumericInput[1]; (** Index 1: System flags **)
GVL.SystemFlags := TO_BYTE(systemFlags AND 16#0001);
GVL.EthercatAliveFromMaster := (systemFlags AND 16#0002) <> 0;
GVL.RemoteMasterAlive := (systemFlags AND 16#0004) <> 0;
maintenanceMode := (systemFlags AND 16#0001) <> 0; (** Maintenance mode flag **)
resetRequest := (systemFlags AND 16#0100) <> 0; (** Bit 8: Manual BIC reset request (OFF->ON sequence) **)
morpheeUseIndividualBicControl := (systemFlags AND 16#0200) <> 0; (** Bit 9: Morphee individual BIC mode request **)
IF NOT GVL.UseTempGroupInputs THEN
  GVL.UseIndividualBicControl := FALSE; (** Force grouped live control path so group setpoints always drive BICs **)
END_IF;

IF resetRequest AND NOT FaultResetRequestPrev THEN
  FOR devIdx := 4 TO 19 DO
    FaultResetState[devIdx] := 1;
    FaultResetCounter[devIdx] := 0;
    CanCtrlConfigured[devIdx] := FALSE;
    BidirAutoConfigured[devIdx] := FALSE;
  END_FOR;
END_IF;
FaultResetRequestPrev := resetRequest;

(** Process EL2809 and EL2798 inputs **)
FOR j:=0 TO 2 DO
GVL.EL2809_InputFlags[j] := GVL.NumericInput[5+j]; (** Index 5: EL2809 flags **)
	FOR i := 0 TO 15 DO
	  GVL.EL2809_Output[j,i] := (GVL.EL2809_InputFlags[j] AND SHL(TO_WORD(1), i)) <> 0;
	END_FOR;
END_FOR;

GVL.EL2798_InputFlags := TO_BYTE(GVL.NumericInput[6]); (** Index 6: EL2798 flags **)
FOR i := 0 TO 7 DO
  GVL.EL2798_Output[i] := (GVL.EL2798_InputFlags AND SHL(TO_BYTE(1), i)) <> 0;
END_FOR;

(** Group-level sourcing is processed directly in this method. **)

(** Process device inputs and queue control commands **)
FOR devIdx := 0 TO 19 DO
  baseIdx := 38 + (devIdx * 7); (** Device inputs start at 38 **)
  isGroupedMaster := FALSE;
  usePerDeviceInputs := TRUE;
  desiredReverse := GVL.Direction[devIdx];

  (* DPU devices 0..3 must always be controlled by their own per-device channels. *)
  IF devIdx <= 3 THEN
    usePerDeviceInputs := TRUE;
  END_IF;
  IF GVL.GroupMembership[devIdx] >= 0 AND GVL.GroupMembership[devIdx] <= 3 THEN
    isGroupedMaster := (GVL.GroupMaster[GVL.GroupMembership[devIdx]] = devIdx);
  END_IF;
  IF NOT maintenanceMode AND NOT GVL.UseIndividualBicControl AND devIdx >= 4 AND GVL.GroupMembership[devIdx] >= 0 AND GVL.GroupMembership[devIdx] <= 3 THEN
    usePerDeviceInputs := FALSE;
  END_IF;

  (** Read device setpoints and flags **)
  IF baseIdx + 6 < SIZEOF(GVL.NumericInput) / SIZEOF(GVL.NumericInput[0]) THEN
    (** Set setpoints for non-master devices or in maintenance mode **)
    IF devIdx <= 3 THEN
      IF GVL.UseTempBus1Direct THEN
        GVL.VoutSetpoint[devIdx] := UINT_TO_REAL(GVL.TempBus1VoutSetpoint[devIdx]); (** Temp Bus1 VoutSetpoint **)
        GVL.IoutSetpoint[devIdx] := UINT_TO_REAL(GVL.TempBus1IoutSetpoint[devIdx]); (** Temp Bus1 IoutSetpoint **)
      ELSE
        GVL.VoutSetpoint[devIdx] := UINT_TO_REAL(GVL.NumericInput[baseIdx]); (** DPU VoutSetpoint **)
        GVL.IoutSetpoint[devIdx] := UINT_TO_REAL(GVL.NumericInput[baseIdx + 1]); (** DPU IoutSetpoint **)
      END_IF;
    ELSIF NOT usePerDeviceInputs THEN
      groupIdx := (devIdx - 4) / 4;
      IF groupIdx >= 0 AND groupIdx <= 3 THEN
        groupInputBaseIdx := GVL.GroupInputBase[groupIdx];
        IF groupInputBaseIdx < 10 OR groupInputBaseIdx > 31 THEN
          groupInputBaseIdx := 10 + (groupIdx * 7); (* Fallback to canonical mapping when config is invalid *)
        END_IF;
        groupVoutRaw := GVL.NumericInput[groupInputBaseIdx];
        groupIoutRawTotal := GVL.NumericInput[groupInputBaseIdx + 1];
        groupOutputRequest := (GVL.NumericInput[groupInputBaseIdx + 2] AND 16#0010) <> 0;

        activeInGroup := 0;
        FOR memberIdx := (groupIdx * 4) + 4 TO (groupIdx * 4) + 7 DO
          IF memberIdx <= 19 THEN
            IF groupOutputRequest THEN
              activeInGroup := activeInGroup + 1;
            END_IF;
          END_IF;
        END_FOR;

        IF activeInGroup > 0 THEN
          groupIoutRawPerDevice := groupIoutRawTotal / activeInGroup;
        ELSE
          groupIoutRawPerDevice := 0;
        END_IF;

        GVL.VoutSetpoint[devIdx] := UINT_TO_REAL(groupVoutRaw);
        IF groupOutputRequest THEN
          GVL.IoutSetpoint[devIdx] := UINT_TO_REAL(groupIoutRawPerDevice);
        ELSE
          GVL.IoutSetpoint[devIdx] := 0.0;
        END_IF;
      END_IF;
    ELSIF GVL.UseIndividualBicControl AND GVL.UseTempGroupInputs AND devIdx >= 4 THEN
      CASE devIdx OF
        4..7: tempBase := 0;
        8..11: tempBase := 7;
        12..15: tempBase := 14;
        16..19: tempBase := 21;
        ELSE tempBase := -1;
      END_CASE;
      IF tempBase >= 0 AND tempBase + 1 < SIZEOF(GVL.TempGroupInput) / SIZEOF(GVL.TempGroupInput[0]) THEN
        GVL.VoutSetpoint[devIdx] := UINT_TO_REAL(GVL.TempGroupInput[tempBase]);
        GVL.IoutSetpoint[devIdx] := UINT_TO_REAL(GVL.TempGroupInput[tempBase + 1]);
      END_IF;
    ELSIF usePerDeviceInputs THEN
      GVL.VoutSetpoint[devIdx] := UINT_TO_REAL(GVL.NumericInput[baseIdx]); (** VoutSetpoint **)
      GVL.IoutSetpoint[devIdx] := UINT_TO_REAL(GVL.NumericInput[baseIdx + 1]); (** IoutSetpoint **)
      IF devIdx >= 4 AND NOT GVL.UseIndividualBicControl THEN
        groupIdx := (devIdx - 4) / 4;
        IF groupIdx >= 0 AND groupIdx <= 3 THEN
          groupInputBaseIdx := GVL.GroupInputBase[groupIdx];
          IF groupInputBaseIdx < 10 OR groupInputBaseIdx > 31 THEN
            groupInputBaseIdx := 10 + (groupIdx * 7);
          END_IF;
          groupOutputRequest := (GVL.NumericInput[groupInputBaseIdx + 2] AND 16#0010) <> 0;
          IF GVL.VoutSetpoint[devIdx] = 0.0 AND GVL.IoutSetpoint[devIdx] = 0.0 AND
             (GVL.NumericInput[groupInputBaseIdx + 2] AND 16#0012) <> 0 THEN
            groupVoutRaw := GVL.NumericInput[groupInputBaseIdx];
            groupIoutRawTotal := GVL.NumericInput[groupInputBaseIdx + 1];
            IF groupOutputRequest THEN
              activeInGroup := 4;
              groupIoutRawPerDevice := groupIoutRawTotal / activeInGroup;
            ELSE
              groupIoutRawPerDevice := 0;
            END_IF;
            GVL.VoutSetpoint[devIdx] := UINT_TO_REAL(groupVoutRaw);
            GVL.IoutSetpoint[devIdx] := UINT_TO_REAL(groupIoutRawPerDevice);
          END_IF;
        END_IF;
      END_IF;
    END_IF;
    IF devIdx <= 3 THEN
      IF GVL.UseTempBus1Direct THEN
        flags := GVL.TempBus1Flags[devIdx]; (** Temp Bus1 device flags **)
      ELSE
        flags := GVL.NumericInput[baseIdx + 2]; (** DPU device flags **)
      END_IF;
    ELSIF NOT usePerDeviceInputs THEN
      groupIdx := (devIdx - 4) / 4;
      IF groupIdx >= 0 AND groupIdx <= 3 THEN
        groupInputBaseIdx := GVL.GroupInputBase[groupIdx];
        IF groupInputBaseIdx < 10 OR groupInputBaseIdx > 31 THEN
          groupInputBaseIdx := 10 + (groupIdx * 7); (* Fallback to canonical mapping when config is invalid *)
        END_IF;
        flags := GVL.NumericInput[groupInputBaseIdx + 2];
      ELSE
        flags := 0;
      END_IF;
    ELSIF GVL.UseIndividualBicControl AND GVL.UseTempGroupInputs AND devIdx >= 4 THEN
      CASE devIdx OF
        4..7: tempBase := 0;
        8..11: tempBase := 7;
        12..15: tempBase := 14;
        16..19: tempBase := 21;
        ELSE tempBase := -1;
      END_CASE;
      IF tempBase >= 0 AND tempBase + 2 < SIZEOF(GVL.TempGroupInput) / SIZEOF(GVL.TempGroupInput[0]) THEN
        flags := GVL.TempGroupInput[tempBase + 2];
      ELSE
        flags := GVL.NumericInput[baseIdx + 2]; (** Device flags **)
      END_IF;
    ELSIF usePerDeviceInputs THEN
      flags := GVL.NumericInput[baseIdx + 2]; (** Device flags **)
      IF devIdx >= 4 AND NOT GVL.UseIndividualBicControl THEN
        groupIdx := (devIdx - 4) / 4;
        IF groupIdx >= 0 AND groupIdx <= 3 THEN
          groupInputBaseIdx := GVL.GroupInputBase[groupIdx];
          IF groupInputBaseIdx < 10 OR groupInputBaseIdx > 31 THEN
            groupInputBaseIdx := 10 + (groupIdx * 7);
          END_IF;
          IF (flags AND 16#0012) = 0 AND (GVL.NumericInput[groupInputBaseIdx + 2] AND 16#0012) <> 0 THEN
            flags := GVL.NumericInput[groupInputBaseIdx + 2];
          END_IF;
        END_IF;
      END_IF;
    ELSE
      flags := 0;
    END_IF;
    
    (** Set device flags in maintenance mode or for devices 0-3 or non-master devices **)
    IF GVL.UseTempBus1Direct AND devIdx <= 3 THEN
      requestedOutputOn := (flags AND 16#0010) <> 0;
      GVL.Voltage[devIdx] := (flags AND 16#0008) <> 0; (** Bit 3: DeviceMode Voltage **)
      GVL.Current[devIdx] := (flags AND 16#0004) <> 0; (** Bit 2: DeviceMode Current **)
      IF GVL.Voltage[devIdx] AND GVL.Current[devIdx] THEN
        GVL.Current[devIdx] := FALSE; (** DPU: prefer voltage mode when both bits are asserted **)
      END_IF;
      GVL.Standby[devIdx] := NOT (GVL.Voltage[devIdx] OR GVL.Current[devIdx]); (** Standby when neither Voltage nor Current **)
      GVL.Direction[devIdx] := (flags AND 16#0001) <> 0; (** Bit 0: Direction **)
      GVL.OperationOn[devIdx] := (flags AND 16#0002) <> 0; (** Bit 1: OperationOn **)
      IF requestedOutputOn AND NOT THIS^.LastOutputOn[devIdx] THEN
        THIS^.LastVoutSetpoint[devIdx] := 0;
        THIS^.LastIoutSetpoint[devIdx] := 0;
        THIS^.LastOperationOn[devIdx] := NOT GVL.OperationOn[devIdx];
        THIS^.LastDirection[devIdx] := NOT GVL.Direction[devIdx];
      END_IF;
      GVL.OutputOn[devIdx] := requestedOutputOn; (** Bit 4: OutputOn **)
      THIS^.LastOutputOn[devIdx] := requestedOutputOn;
    ELSIF usePerDeviceInputs THEN
      requestedOutputOn := (flags AND 16#0010) <> 0;
      GVL.Voltage[devIdx] := (flags AND 16#0008) <> 0; (** Bit 3: DeviceMode Voltage **)
      GVL.Current[devIdx] := (flags AND 16#0004) <> 0; (** Bit 2: DeviceMode Current **)
      IF devIdx <= 3 AND GVL.Voltage[devIdx] AND GVL.Current[devIdx] THEN
        GVL.Current[devIdx] := FALSE; (** DPU: prefer voltage mode when both bits are asserted **)
      END_IF;
      GVL.Standby[devIdx] := NOT (GVL.Voltage[devIdx] OR GVL.Current[devIdx]); (** Standby when neither Voltage nor Current **)
      GVL.Direction[devIdx] := (flags AND 16#0001) <> 0; (** Bit 0: Direction **)
      GVL.OperationOn[devIdx] := (flags AND 16#0002) <> 0; (** Bit 1: OperationOn **)
      IF requestedOutputOn AND NOT THIS^.LastOutputOn[devIdx] THEN
        THIS^.LastVoutSetpoint[devIdx] := 0;
        THIS^.LastIoutSetpoint[devIdx] := 0;
        THIS^.LastOperationOn[devIdx] := NOT GVL.OperationOn[devIdx];
        THIS^.LastDirection[devIdx] := NOT GVL.Direction[devIdx];
      END_IF;
      GVL.OutputOn[devIdx] := requestedOutputOn; (** Bit 4: OutputOn **)
      THIS^.LastOutputOn[devIdx] := requestedOutputOn;
    ELSE
      (** Group mode: apply mode/command bits from this device's own group flags every cycle. **)
      requestedOutputOn := (flags AND 16#0010) <> 0;
      GVL.Voltage[devIdx] := (flags AND 16#0008) <> 0;
      GVL.Current[devIdx] := (flags AND 16#0004) <> 0;
      GVL.Standby[devIdx] := NOT (GVL.Voltage[devIdx] OR GVL.Current[devIdx]);
      GVL.Direction[devIdx] := (flags AND 16#0001) <> 0;
      GVL.OperationOn[devIdx] := (flags AND 16#0002) <> 0;
      IF requestedOutputOn AND NOT THIS^.LastOutputOn[devIdx] THEN
        THIS^.LastVoutSetpoint[devIdx] := 0;
        THIS^.LastIoutSetpoint[devIdx] := 0;
        THIS^.LastOperationOn[devIdx] := NOT GVL.OperationOn[devIdx];
        THIS^.LastDirection[devIdx] := NOT GVL.Direction[devIdx];
      END_IF;
      GVL.OutputOn[devIdx] := requestedOutputOn;
      THIS^.LastOutputOn[devIdx] := requestedOutputOn;
    END_IF;

    (* Use active-cycle command flags as the source of truth for direction when choosing VOUT command type. *)
    desiredReverse := (flags AND 16#0001) <> 0;

    (* Global mode arbitration: if both bits are asserted by upstream UI/PLC mapping,
       prefer voltage mode so reverse-voltage tracking stays on the CV command path. *)
    IF GVL.Voltage[devIdx] AND GVL.Current[devIdx] THEN
      GVL.Current[devIdx] := FALSE;
      GVL.Standby[devIdx] := FALSE;
    END_IF;

    IF devIdx <= 3 AND GVL.OutputOn[devIdx] AND GVL.OperationOn[devIdx] THEN
      (* Keep strict Morphee OutputOn/OperationOn gating.
         If mode bits are both cleared during HMI reconnect, default DPU to voltage mode
         so nonzero requested voltage setpoints are not blocked by standby. *)
      IF GVL.Standby[devIdx] AND GVL.VoutSetpoint[devIdx] > 0.0 THEN
        GVL.Voltage[devIdx] := TRUE;
        GVL.Current[devIdx] := FALSE;
        GVL.Standby[devIdx] := FALSE;
      END_IF;
    END_IF;

    GVL.OrangeStop[devIdx] := (flags AND 16#0020) <> 0; (** Bit 5: OrangeStop **)
    GVL.RedStop[devIdx] := (flags AND 16#0040) <> 0; (** Bit 6: RedStop **)
    GVL.EStop[devIdx] := (flags AND 16#0080) <> 0; (** Bit 7: EStop **)
  END_IF;

  (** Manual fault-reset sequence for BICs: force OPERATION OFF then ON. **)
  IF devIdx >= 4 AND FaultResetState[devIdx] <> 0 THEN
    CASE FaultResetState[devIdx] OF
      1:
        IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_OPERATION, 0) THEN
          THIS^.LastOperationOn[devIdx] := FALSE;
          FaultResetState[devIdx] := 2;
          FaultResetCounter[devIdx] := 0;
        END_IF;
      2:
        FaultResetCounter[devIdx] := FaultResetCounter[devIdx] + 1;
        IF FaultResetCounter[devIdx] >= 2 THEN
          IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_OPERATION, 1) THEN
            GVL.OperationOn[devIdx] := TRUE;
            THIS^.LastOperationOn[devIdx] := TRUE;
            GVL.RecoveryPending[devIdx] := FALSE;
            FaultResetState[devIdx] := 0;
            FaultResetCounter[devIdx] := 0;
          END_IF;
        END_IF;
    END_CASE;
  ELSE
    (** Queue direction command only when requested direction changes.
        Avoid retrying every cycle on feedback mismatch, which can starve later commands under 50 ms pacing. **)
    IF GVL.Direction[devIdx] <> THIS^.LastDirection[devIdx] THEN
      IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_DIRECTION_CTRL, BOOL_TO_UINT(GVL.Direction[devIdx])) THEN (** CMD_DIRECTION_CTRL **)
        THIS^.LastDirection[devIdx] := GVL.Direction[devIdx];
        (* Direction changed: force resend of setpoints in the new direction command space. *)
        THIS^.LastVoutSetpoint[devIdx] := 0;
        THIS^.LastIoutSetpoint[devIdx] := 0;
      END_IF;
    END_IF;

    (** Queue operation command **)
    IF GVL.OperationOn[devIdx] <> THIS^.LastOperationOn[devIdx] THEN
      IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_OPERATION, BOOL_TO_UINT(GVL.OperationOn[devIdx])) THEN (** CMD_OPERATION **)
        THIS^.LastOperationOn[devIdx] := GVL.OperationOn[devIdx];
        IF GVL.OperationOn[devIdx] THEN
          (* Trigger one clean resend of setpoints after OPERATION is acknowledged. *)
          THIS^.LastVoutSetpoint[devIdx] := 0;
          THIS^.LastIoutSetpoint[devIdx] := 0;
        END_IF;
      END_IF;
    END_IF;

    (** Queue setpoint commands based on DeviceMode and Direction **)
    IF GVL.Standby[devIdx] THEN
    (** Standby mode **)
    IF THIS^.LastVoutSetpoint[devIdx] <> 0 THEN
      IF desiredReverse THEN
        IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_REVERSE_VOUT_SET, 0) THEN (** CMD_REVERSE_VOUT_SET, 0 **)
          GVL.VoutSetRev[devIdx] := 0.0; (** Clear reverse Vout setpoint **)
          THIS^.LastVoutSetpoint[devIdx] := 0;
        END_IF;
      ELSE
        IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_VOUT_SET, 0) THEN (** CMD_VOUT_SET, 0 **)
          GVL.VoutSetpoint[devIdx] := 0.0; (** Clear forward Vout setpoint **)
          THIS^.LastVoutSetpoint[devIdx] := 0;
        END_IF;
      END_IF;
    END_IF;
    IF THIS^.LastIoutSetpoint[devIdx] <> 0 THEN
      IF GVL.Direction[devIdx] THEN
        IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_REVERSE_IOUT_SET, 0) THEN (** CMD_REVERSE_IOUT_SET, 0 **)
          GVL.IoutSetRev[devIdx] := 0.0; (** Clear reverse Iout setpoint **)
          THIS^.LastIoutSetpoint[devIdx] := 0;
        END_IF;
      ELSE
        IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_IOUT_SET, 0) THEN (** CMD_IOUT_SET, 0 **)
          GVL.IoutSetpoint[devIdx] := 0.0; (** Clear forward Iout setpoint **)
          THIS^.LastIoutSetpoint[devIdx] := 0;
        END_IF;
      END_IF;
    END_IF;
  ELSIF GVL.Current[devIdx] THEN
    (** Current mode **)
    (* Only clamp if limits are non-zero; 0 means Morphee has not set the limit *)
    setpointIout := GVL.IoutSetpoint[devIdx] / 100.0;
    IF THIS^.IoutSetMin[devIdx] > 0 THEN
      setpointIout := MAX(setpointIout, UINT_TO_REAL(THIS^.IoutSetMin[devIdx]));
    END_IF;
    IF THIS^.IoutSetMax[devIdx] > 0 THEN
      setpointIout := MIN(setpointIout, UINT_TO_REAL(THIS^.IoutSetMax[devIdx]));
    END_IF;
    IF devIdx >= 4 THEN
      IF GVL.Direction[devIdx] THEN
        setpointIout := MIN(setpointIout, GVL_Constant.BIC24_IOUT_MAX_REV);
      ELSE
        setpointIout := MIN(setpointIout, GVL_Constant.BIC24_IOUT_MAX_FWD);
      END_IF;
    END_IF;
    IF devIdx <= 3 THEN
      clampedIout := REAL_TO_UINT(setpointIout * 10.0);   (** DPU F=0.1 **)
    ELSE
      factorNibble := SHR((GVL.VoutScale[devIdx] AND 16#00F0), 4);
      CASE factorNibble OF
        16#4: clampedIout := REAL_TO_UINT(setpointIout * 1000.0);
        16#5: clampedIout := REAL_TO_UINT(setpointIout * 100.0);
        16#6: clampedIout := REAL_TO_UINT(setpointIout * 10.0);
        16#7: clampedIout := REAL_TO_UINT(setpointIout);
        16#8: clampedIout := REAL_TO_UINT(setpointIout * 0.1);
        16#9: clampedIout := REAL_TO_UINT(setpointIout * 0.01);
        ELSE clampedIout := REAL_TO_UINT(setpointIout * 100.0);
      END_CASE;
    END_IF;
     IF clampedIout <> THIS^.LastIoutSetpoint[devIdx] THEN
      IF GVL.Direction[devIdx] THEN
        IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_REVERSE_IOUT_SET, clampedIout) THEN (** CMD_REVERSE_IOUT_SET **)
          THIS^.LastIoutSetpoint[devIdx] := clampedIout;
        END_IF;
      ELSE
        IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_IOUT_SET, clampedIout) THEN (** CMD_IOUT_SET **)
          THIS^.LastIoutSetpoint[devIdx] := clampedIout;
        END_IF;
      END_IF;
    END_IF;
    (** CC mode voltage ceiling for BIC devices: 5% margin below 28V hardware max *)
    IF devIdx >= 4 THEN
      IF NOT maintenanceMode AND NOT GVL.UseIndividualBicControl THEN
        groupIdx := (devIdx - 4) / 4;
        IF groupIdx >= 0 AND groupIdx <= 3 THEN
          groupInputBaseIdx := GVL.GroupInputBase[groupIdx];
          IF groupInputBaseIdx < 10 OR groupInputBaseIdx > 31 THEN
            groupInputBaseIdx := 10 + (groupIdx * 7); (* Fallback to canonical mapping when config is invalid *)
          END_IF;
          groupVoutRaw := GVL.NumericInput[groupInputBaseIdx];
          setpointVout := UINT_TO_REAL(groupVoutRaw) / 100.0; (* Morphee always sends x100: 2200 = 22.00V *)
        ELSE
          setpointVout := GVL.VoutSetpoint[devIdx] / 100.0;
        END_IF;
      ELSE
        setpointVout := GVL.VoutSetpoint[devIdx] / 100.0;
      END_IF;

      IF GVL.Direction[devIdx] THEN
        (* Reverse CC: REVERSE_VOUT_SET = lower voltage protection, floored at MIN_VOLTAGE *)
        setpointVout := MAX(setpointVout, UINT_TO_REAL(GVL_Constant.MIN_VOLTAGE));
      ELSE
        (* Forward CC: VOUT_SET = upper voltage ceiling, capped at VoutSetMax from group/operator limits *)
        setpointVout := MAX(setpointVout, UINT_TO_REAL(GVL_Constant.MIN_VOLTAGE));
        IF NOT maintenanceMode AND NOT GVL.UseIndividualBicControl THEN
          setpointVout := MIN(setpointVout, UINT_TO_REAL(GVL_Constant.MAX_VOLTAGE));
        ELSIF THIS^.VoutSetMax[devIdx] > 0 THEN
          setpointVout := MIN(setpointVout, UINT_TO_REAL(THIS^.VoutSetMax[devIdx]));
        ELSE
          setpointVout := MIN(setpointVout, UINT_TO_REAL(GVL_Constant.MAX_VOLTAGE));
        END_IF;
      END_IF;
      factorNibble := GVL.VoutScale[devIdx] AND 16#000F;
      CASE factorNibble OF
        16#4: clampedVout := REAL_TO_UINT(setpointVout * 1000.0);
        16#5: clampedVout := REAL_TO_UINT(setpointVout * 100.0);
        16#6: clampedVout := REAL_TO_UINT(setpointVout * 10.0);
        16#7: clampedVout := REAL_TO_UINT(setpointVout);
        16#8: clampedVout := REAL_TO_UINT(setpointVout * 0.1);
        16#9: clampedVout := REAL_TO_UINT(setpointVout * 0.01);
        ELSE clampedVout := REAL_TO_UINT(setpointVout * 100.0);
      END_CASE;
      IF clampedVout <> THIS^.LastVoutSetpoint[devIdx] THEN
        IF desiredReverse THEN
          IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_REVERSE_VOUT_SET, clampedVout) THEN
            THIS^.LastVoutSetpoint[devIdx] := clampedVout;
          END_IF;
        ELSE
          IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_VOUT_SET, clampedVout) THEN
            THIS^.LastVoutSetpoint[devIdx] := clampedVout;
          END_IF;
        END_IF;
      END_IF;
    END_IF;
  ELSIF GVL.Voltage[devIdx] THEN
    (** Voltage mode **)
    (* Send VOUT first so it always gets the pacing slot; IOUT (current limit) follows next cycle. *)
    IF devIdx >= 4 THEN
      IF NOT maintenanceMode AND NOT GVL.UseIndividualBicControl THEN
        groupIdx := (devIdx - 4) / 4;
        IF groupIdx >= 0 AND groupIdx <= 3 THEN
          groupInputBaseIdx := GVL.GroupInputBase[groupIdx];
          IF groupInputBaseIdx < 10 OR groupInputBaseIdx > 31 THEN
            groupInputBaseIdx := 10 + (groupIdx * 7); (* Fallback to canonical mapping when config is invalid *)
          END_IF;
          groupVoutRaw := GVL.NumericInput[groupInputBaseIdx];
          setpointVout := UINT_TO_REAL(groupVoutRaw) / 100.0; (* Morphee always sends x100: 2200 = 22.00V *)
        ELSE
          setpointVout := GVL.VoutSetpoint[devIdx] / 100.0;
        END_IF;
      ELSE
        setpointVout := GVL.VoutSetpoint[devIdx] / 100.0;
      END_IF;

      (* Hardware bounds always applied *)
      setpointVout := MAX(setpointVout, UINT_TO_REAL(GVL_Constant.MIN_VOLTAGE));
      setpointVout := MIN(setpointVout, UINT_TO_REAL(GVL_Constant.MAX_VOLTAGE));
      (* Operator limits from Morphee: applied only when non-zero (tighter than hardware range) *)
      IF THIS^.VoutSetMin[devIdx] > 0 THEN
        setpointVout := MAX(setpointVout, UINT_TO_REAL(THIS^.VoutSetMin[devIdx]));
      END_IF;
      IF THIS^.VoutSetMax[devIdx] > 0 THEN
        setpointVout := MIN(setpointVout, UINT_TO_REAL(THIS^.VoutSetMax[devIdx]));
      END_IF;
    ELSE
      (* DPU VOUT_SET uses F=0.1 wire format: Morphee sends x100 (e.g. 2670 = 26.70V) → /100 → 26.7V → x10 = 267 wire *)
      setpointVout := GVL.VoutSetpoint[devIdx] / 100.0;
      IF THIS^.VoutSetMin[devIdx] > 0 THEN
        setpointVout := MAX(setpointVout, UINT_TO_REAL(THIS^.VoutSetMin[devIdx]));
      END_IF;
      IF THIS^.VoutSetMax[devIdx] > 0 THEN
        setpointVout := MIN(setpointVout, UINT_TO_REAL(THIS^.VoutSetMax[devIdx]));
      END_IF;
    END_IF;
    IF devIdx <= 3 THEN
      clampedVout := REAL_TO_UINT(setpointVout * 10.0);   (** DPU F=0.1: 30V = 300 **)
    ELSE
      factorNibble := GVL.VoutScale[devIdx] AND 16#000F;
      CASE factorNibble OF
        16#4: clampedVout := REAL_TO_UINT(setpointVout * 1000.0);
        16#5: clampedVout := REAL_TO_UINT(setpointVout * 100.0);
        16#6: clampedVout := REAL_TO_UINT(setpointVout * 10.0);
        16#7: clampedVout := REAL_TO_UINT(setpointVout);
        16#8: clampedVout := REAL_TO_UINT(setpointVout * 0.1);
        16#9: clampedVout := REAL_TO_UINT(setpointVout * 0.01);
        ELSE clampedVout := REAL_TO_UINT(setpointVout * 100.0);
      END_CASE;
    END_IF;
     IF clampedVout <> THIS^.LastVoutSetpoint[devIdx] THEN
      IF desiredReverse THEN
        IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_REVERSE_VOUT_SET, clampedVout) THEN (** CMD_REVERSE_VOUT_SET **)
          THIS^.LastVoutSetpoint[devIdx] := clampedVout;
        END_IF;
      ELSE
        IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_VOUT_SET, clampedVout) THEN (** CMD_VOUT_SET **)
          THIS^.LastVoutSetpoint[devIdx] := clampedVout;
        END_IF;
      END_IF;
    END_IF;

    END_IF;
    (* Current limit tracking: send IOUT after VOUT so voltage setpoint gets priority for pacing. *)
    setpointIout := GVL.IoutSetpoint[devIdx] / 100.0;
    IF THIS^.IoutSetMin[devIdx] > 0 THEN
      setpointIout := MAX(setpointIout, UINT_TO_REAL(THIS^.IoutSetMin[devIdx]));
    END_IF;
    IF THIS^.IoutSetMax[devIdx] > 0 THEN
      setpointIout := MIN(setpointIout, UINT_TO_REAL(THIS^.IoutSetMax[devIdx]));
    END_IF;
    IF devIdx >= 4 THEN
      IF GVL.Direction[devIdx] THEN
        setpointIout := MIN(setpointIout, GVL_Constant.BIC24_IOUT_MAX_REV);
      ELSE
        setpointIout := MIN(setpointIout, GVL_Constant.BIC24_IOUT_MAX_FWD);
      END_IF;
    END_IF;
    IF devIdx <= 3 THEN
      clampedIout := REAL_TO_UINT(setpointIout * 10.0);   (** DPU F=0.1 **)
    ELSE
      factorNibble := SHR((GVL.VoutScale[devIdx] AND 16#00F0), 4);
      CASE factorNibble OF
        16#4: clampedIout := REAL_TO_UINT(setpointIout * 1000.0);
        16#5: clampedIout := REAL_TO_UINT(setpointIout * 100.0);
        16#6: clampedIout := REAL_TO_UINT(setpointIout * 10.0);
        16#7: clampedIout := REAL_TO_UINT(setpointIout);
        16#8: clampedIout := REAL_TO_UINT(setpointIout * 0.1);
        16#9: clampedIout := REAL_TO_UINT(setpointIout * 0.01);
        ELSE clampedIout := REAL_TO_UINT(setpointIout * 100.0);
      END_CASE;
    END_IF;
    IF clampedIout <> THIS^.LastIoutSetpoint[devIdx] THEN
      IF GVL.Direction[devIdx] THEN
        IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_REVERSE_IOUT_SET, clampedIout) THEN
          THIS^.LastIoutSetpoint[devIdx] := clampedIout;
        END_IF;
      ELSE
        IF THIS^.ApplyCommands(devIdx, GVL_Constant.CMD_IOUT_SET, clampedIout) THEN
          THIS^.LastIoutSetpoint[devIdx] := clampedIout;
        END_IF;
      END_IF;
    END_IF;
  END_IF;
END_FOR;]]></ST>
      </Implementation>
    </Method>
    <Method Name="ReadLimits" Id="{0cee76ab-620c-4b89-985e-d5b10c795a48}">
      <Declaration><![CDATA[METHOD ReadLimits
VAR
  devIdx : INT;                            (* Device index *)
  baseIdx : INT;                           (* Base index for device inputs *)
  inputIdx : INT;                          (* Base index for group inputs *)
  groupIdx : INT;                          (* Group index *)
  masterIdx : INT;                         (* Master device index *)
  maintenanceMode : BOOL;                  (* Maintenance mode status *)
  tempBase : INT;                          (* Temp: offset into TempGroupInput array *)
  dirIoutMax : UINT;                       (* Direction-dependent BIC max current [A] *)
  groupIoutLimitInput : UINT;              (* Group Iout max limit input before capacity constraint *)
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
(* Comment Section: GVL.NumericInput Mapping for ReadLimits *)
(* This method reads individual setpoints/limits for all devices and applies *)
(* group-level setpoints/limits to the master device in normal mode. Group limits *)
(* (e.g., GroupIoutSetMax) are constrained by GVL.GroupCapacity, set by GroupManager *)
(* based on healthy units. GVL.GroupMaster serves as the group device index, *)
(* enabling groups when valid (4-19). *)

(* GVL.NumericInput Mapping *)
(* 0-4: System-Level Inputs *)
(*   0: GVL.SystemAlarms *)
(*   1: System Flags (maintenanceMode read here) *)
(*   2: Morphee Signal *)
(*   3-4: Reserved *)
(* 5-9: Unallocated *)
(* 10-37: Group Inputs (4 groups x 7 inputs) *)
(*   - For groupIdx = 0 TO 3, baseIdx = 10 + (groupIdx * 7): *)
(*     baseIdx: GroupVoutSetpoint *)
(*     baseIdx + 1: GroupIoutSetpoint *)
(*     baseIdx + 2: Group Flags *)
(*     baseIdx + 3: GroupVoutSetMin *)
(*     baseIdx + 4: GroupVoutSetMax *)
(*     baseIdx + 5: GroupIoutSetMin *)
(*     baseIdx + 6: GroupIoutSetMax *)
(*   - Applied to master device here if valid *)
(* 38-177: Device Inputs (20 devices x 7 inputs) *)
(*   - For devIdx = 0 TO 19, baseIdx = 38 + (devIdx * 7): *)
(*     baseIdx: VoutSetpoint *)
(*     baseIdx + 1: IoutSetpoint *)
(*     baseIdx + 2: Flags *)
(*     baseIdx + 3: VoutSetMin *)
(*     baseIdx + 4: VoutSetMax *)
(*     baseIdx + 5: IoutSetMin *)
(*     baseIdx + 6: IoutSetMax *)
(* 178+: Unallocated *)

(* Read maintenance mode *)
maintenanceMode := (GVL.NumericInput[1] AND 16#0001) <> 0; (* Index 1, bit 0 *)

(* Set individual device setpoints and limits *)
FOR devIdx := 0 TO 19 DO
  baseIdx := 38 + (devIdx * 7);
  IF baseIdx + 6 < SIZEOF(GVL.NumericInput) / SIZEOF(GVL.NumericInput[0]) THEN
    IF GVL.UseTempBus1Direct AND devIdx <= 3 THEN
      VoutSetpoint[devIdx] := GVL.TempBus1VoutSetpoint[devIdx];
      IoutSetpoint[devIdx] := GVL.TempBus1IoutSetpoint[devIdx];
      VoutSetMin[devIdx] := GVL.TempBus1VoutSetMin[devIdx] / 100;
      VoutSetMax[devIdx] := GVL.TempBus1VoutSetMax[devIdx] / 100;
      IoutSetMin[devIdx] := GVL.TempBus1IoutSetMin[devIdx] / 100;
      IoutSetMax[devIdx] := GVL.TempBus1IoutSetMax[devIdx] / 100;
    ELSIF GVL.UseIndividualBicControl AND GVL.UseTempGroupInputs AND devIdx >= 4 THEN
      CASE devIdx OF
        4..7: tempBase := 0;
        8..11: tempBase := 7;
        12..15: tempBase := 14;
        16..19: tempBase := 21;
        ELSE tempBase := -1;
      END_CASE;
      IF tempBase >= 0 AND tempBase + 6 < SIZEOF(GVL.TempGroupInput) / SIZEOF(GVL.TempGroupInput[0]) THEN
        VoutSetpoint[devIdx] := GVL.TempGroupInput[tempBase];
        IoutSetpoint[devIdx] := GVL.TempGroupInput[tempBase + 1];
        VoutSetMin[devIdx] := GVL.TempGroupInput[tempBase + 3] / 100;
        VoutSetMax[devIdx] := GVL.TempGroupInput[tempBase + 4] / 100;
        IoutSetMin[devIdx] := GVL.TempGroupInput[tempBase + 5] / 100;
        IoutSetMax[devIdx] := GVL.TempGroupInput[tempBase + 6] / 100;
      END_IF;
    ELSE
      VoutSetpoint[devIdx] := GVL.NumericInput[baseIdx];
      IoutSetpoint[devIdx] := GVL.NumericInput[baseIdx + 1];
      IF devIdx >= 4 THEN
        VoutSetMin[devIdx] := GVL.NumericInput[baseIdx + 3] / 100;
        VoutSetMax[devIdx] := GVL.NumericInput[baseIdx + 4] / 100;
        IoutSetMin[devIdx] := GVL.NumericInput[baseIdx + 5] / 100;
        IoutSetMax[devIdx] := GVL.NumericInput[baseIdx + 6] / 100;
      ELSE
        IF GVL.NumericInput[baseIdx + 3] > 500 THEN
          VoutSetMin[devIdx] := GVL.NumericInput[baseIdx + 3] / 100;
        ELSE
          VoutSetMin[devIdx] := GVL.NumericInput[baseIdx + 3];
        END_IF;
        IF GVL.NumericInput[baseIdx + 4] > 500 THEN
          VoutSetMax[devIdx] := GVL.NumericInput[baseIdx + 4] / 100;
        ELSE
          VoutSetMax[devIdx] := GVL.NumericInput[baseIdx + 4];
        END_IF;
        IF GVL.NumericInput[baseIdx + 5] > 500 THEN
          IoutSetMin[devIdx] := GVL.NumericInput[baseIdx + 5] / 100;
        ELSE
          IoutSetMin[devIdx] := GVL.NumericInput[baseIdx + 5];
        END_IF;
        IF GVL.NumericInput[baseIdx + 6] > 500 THEN
          IoutSetMax[devIdx] := GVL.NumericInput[baseIdx + 6] / 100;
        ELSE
          IoutSetMax[devIdx] := GVL.NumericInput[baseIdx + 6];
        END_IF;
      END_IF;
    END_IF;
  END_IF;

  (* Group-level setpoints/limits are applied in ProcessInputs for all grouped devices.
     Skip the legacy master-override path here to avoid cross-group overwrite races. *)
  IF NOT maintenanceMode AND devIdx >= 4 AND GVL.UseIndividualBicControl THEN
    FOR groupIdx := 0 TO 3 DO
      masterIdx := GVL.GroupMaster[groupIdx];
      IF masterIdx >= 4 AND masterIdx <= 19 THEN
        IF NOT GVL.SafetyShutdown[masterIdx] THEN
        inputIdx := GVL.GroupInputBase[groupIdx]; (* Per-group configurable base; default = 10+groupIdx*7 *)
        IF devIdx = masterIdx THEN
          IF inputIdx + 6 < SIZEOF(GVL.NumericInput) / SIZEOF(GVL.NumericInput[0]) THEN
            IF GVL.UseTempGroupInputs THEN
              tempBase := inputIdx - 10; (* Map group base (10..) to TempGroupInput (0..) *)
              IF tempBase >= 0 AND tempBase + 6 < SIZEOF(GVL.TempGroupInput) / SIZEOF(GVL.TempGroupInput[0]) THEN
                VoutSetpoint[masterIdx] := GVL.TempGroupInput[tempBase];
                IoutSetpoint[masterIdx] := GVL.TempGroupInput[tempBase + 1];
                VoutSetMin[masterIdx] := GVL.TempGroupInput[tempBase + 3] / 100;
                VoutSetMax[masterIdx] := GVL.TempGroupInput[tempBase + 4] / 100;
                IoutSetMin[masterIdx] := GVL.TempGroupInput[tempBase + 5] / 100;
                groupIoutLimitInput := GVL.TempGroupInput[tempBase + 6];
                IF groupIoutLimitInput = 0 THEN
                  groupIoutLimitInput := GVL.GroupCapacity[groupIdx];
                END_IF;
                IoutSetMax[masterIdx] := MIN(groupIoutLimitInput, GVL.GroupCapacity[groupIdx]); (* Constrain by capacity *)
              END_IF;
            ELSE
              VoutSetpoint[masterIdx] := GVL.NumericInput[inputIdx];
              IoutSetpoint[masterIdx] := GVL.NumericInput[inputIdx + 1];
              IF GVL.NumericInput[inputIdx + 3] > 500 THEN
                VoutSetMin[masterIdx] := GVL.NumericInput[inputIdx + 3] / 100;
              ELSE
                VoutSetMin[masterIdx] := GVL.NumericInput[inputIdx + 3];
              END_IF;
              IF GVL.NumericInput[inputIdx + 4] > 500 THEN
                VoutSetMax[masterIdx] := GVL.NumericInput[inputIdx + 4] / 100;
              ELSE
                VoutSetMax[masterIdx] := GVL.NumericInput[inputIdx + 4];
              END_IF;
              IF GVL.NumericInput[inputIdx + 5] > 500 THEN
                IoutSetMin[masterIdx] := GVL.NumericInput[inputIdx + 5] / 100;
              ELSE
                IoutSetMin[masterIdx] := GVL.NumericInput[inputIdx + 5];
              END_IF;
              groupIoutLimitInput := GVL.NumericInput[inputIdx + 6];
              IF groupIoutLimitInput = 0 THEN
                groupIoutLimitInput := GVL.GroupCapacity[groupIdx];
              END_IF;
              IF groupIoutLimitInput > 500 THEN
                IoutSetMax[masterIdx] := MIN(groupIoutLimitInput / 100, GVL.GroupCapacity[groupIdx]);
              ELSE
                IoutSetMax[masterIdx] := MIN(groupIoutLimitInput, GVL.GroupCapacity[groupIdx]);
              END_IF; (* Constrain by capacity *)
            END_IF;
          END_IF;
        END_IF;
        END_IF;
      END_IF;
    END_FOR;
  END_IF;

  (* Live-path sanitization for BIC limits (applies outside SetpointTest too). *)
  IF devIdx >= 4 THEN
    IF VoutSetMin[devIdx] = 0 THEN
      VoutSetMin[devIdx] := GVL_Constant.MIN_VOLTAGE;
    END_IF;
    IF VoutSetMax[devIdx] = 0 THEN
      VoutSetMax[devIdx] := GVL_Constant.MAX_VOLTAGE;
    END_IF;

    VoutSetMin[devIdx] := MAX(VoutSetMin[devIdx], GVL_Constant.MIN_VOLTAGE);
    VoutSetMax[devIdx] := MIN(VoutSetMax[devIdx], GVL_Constant.MAX_VOLTAGE);
    IF VoutSetMin[devIdx] > VoutSetMax[devIdx] THEN
      VoutSetMin[devIdx] := VoutSetMax[devIdx];
    END_IF;

    IF GVL.Direction[devIdx] THEN
      dirIoutMax := REAL_TO_UINT(GVL_Constant.BIC24_IOUT_MAX_REV);
    ELSE
      dirIoutMax := REAL_TO_UINT(GVL_Constant.BIC24_IOUT_MAX_FWD);
    END_IF;

    IF IoutSetMax[devIdx] = 0 THEN
      IoutSetMax[devIdx] := dirIoutMax;
    END_IF;
    IoutSetMax[devIdx] := MIN(IoutSetMax[devIdx], dirIoutMax);
    IF IoutSetMin[devIdx] > IoutSetMax[devIdx] THEN
      IoutSetMin[devIdx] := IoutSetMax[devIdx];
    END_IF;
  END_IF;
END_FOR;]]></ST>
      </Implementation>
    </Method>
    <Method Name="UpdateOutputs" Id="{c3d4e5f6-3456-7890-1234-56789abcdef0}">
      <Declaration><![CDATA[METHOD UpdateOutputs
VAR
  devIdx : INT;                            (* Device index *)
  baseIdx : INT;                           (* Base index for output array *)
  systemAlarms : DWORD;                    (* System alarms for output *)
  maintenanceMode : BOOL;                  (* Maintenance mode status *)
  cmdId : BYTE;                            (* Command ID for init data *)
  cmdOffset : INT;                         (* Command offset for init frame *)
  i : INT;                                 (* Loop variable for commands *)
  j : INT;                                 (* Loop variable for data pairs *)
  idx : INT;                               (* Output array index *)
  watchDog : BOOL;                         (* Watchdog toggle for output *)
  updatingInMorpheeTableInprogress : Bool := FALSE;
  groupIdx : INT;                          (* Group index *)
  masterIdx : INT;                         (* Master device index *)
  groupBase : INT;                         (* Base index for group devices *)
  opCount : UINT;                          (* Count of devices with OperationOn *)
  outCount : UINT;                         (* Count of devices with OutputOn *)
  initTimeoutCounter : UINT;               (* Counter for forced init exit *)
  commandCount : UINT;                     (* Commands per cycle *)
  commandArray : ARRAY[0..8] OF BYTE := [16#80, 16#81, 16#82, 16#83, 16#84, 16#85, 16#86, 16#87, 16#88];
  commandIndex : INT;
  upperBound : INT;                        (* Upper bound for FOR loop *)
	scaledVin: INT; (** Scaled input voltage **)
	scaledVout: UINT; (** Scaled output voltage **)
  scaledIout: INT; (** Scaled current, signed for discharge export **)
	scaledTemp: UINT; (** Scaled temperature **)
	scaledFanSpeed1: INT; (** Scaled fan speed 1 **)
	scaledFanSpeed2: INT; (** Scaled fan speed 2 **)
	scaledIin: INT; (** Scaled input current **)
  signedIoutRaw: INT; (** Raw signed current decoded from UINT storage **)
	tempScale: UINT; (** Temporary variable for scaling factor extraction **)
	scaleValue: UINT; (** Extracted 4-bit scaling value **)
  systemFlagsOut : UINT;                  (* Device system status word sent to EtherCAT *)
  activeInGroupX10 : UINT;                (* Active healthy devices in group for scaled capacity export *)
  perDeviceLimitX10 : UINT;               (* Direction-dependent per-device current limit in x10 A *)
  perDeviceLimitFwdX10 : UINT;            (* Per-device forward current hard limit in x10 A *)
  perDeviceLimitRevX10 : UINT;            (* Per-device reverse current hard limit in x10 A *)
  groupLimitFwdX10 : UINT;                (* Group forward current hard limit in x10 A *)
  groupLimitRevX10 : UINT;                (* Group reverse current hard limit in x10 A *)
  absVminX100 : UINT;                     (* Absolute voltage minimum in x100 V *)
  absVmaxX100 : UINT;                     (* Absolute voltage maximum in x100 V *)
  reverseMode : BOOL;                     (* TRUE when group direction is reverse *)
  memberIdx : INT;                        (* Member index inside a BIC group *)
  groupAggVinRaw : UDINT;                 (* Sum of raw Vin across healthy devices in a group *)
  groupAggVoutRaw : UDINT;                (* Sum of raw Vout across healthy devices in a group *)
  groupAvgVinRaw : UDINT;                 (* Average raw Vin across healthy devices in a group *)
  groupAvgVoutRaw : UDINT;                (* Average raw Vout across healthy devices in a group *)
  groupAggIoutRaw : DINT;                 (* Sum of raw signed Iout across healthy devices in a group *)
  groupMaxTempRaw : UINT;                 (* Max raw temperature across healthy devices in a group *)
  groupMinFan1Raw : UINT;                 (* Min raw fan1 speed across healthy devices in a group *)
  groupMinFan2Raw : UINT;                 (* Min raw fan2 speed across healthy devices in a group *)
  groupActiveCount : UINT;                (* Healthy active device count used for group feedback aggregation *)
  groupFaultStatusAgg : UINT;             (* Bitwise OR fault status across all devices in the group *)
  aggDirection : BOOL;                    (* Aggregated direction status for group master output *)
  aggOperationOn : BOOL;                  (* Aggregated operation status for group master output *)
  aggCurrentMode : BOOL;                  (* Aggregated current-mode status for group master output *)
  aggVoltageMode : BOOL;                  (* Aggregated voltage-mode status for group master output *)
  aggOutputOn : BOOL;                     (* Aggregated output-on status for group master output *)
  aggOrangeStop : BOOL;                   (* Aggregated orange-stop status for group master output *)
  aggRedStop : BOOL;                      (* Aggregated red-stop status for group master output *)
  aggEStop : BOOL;                        (* Aggregated e-stop status for group master output *)
  aggTempFaultHigh : BOOL;                (* Aggregated high-temperature flag for group master output *)
 
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[(* One-time reset of GVL variables *)
IF GVL.FirstRun THEN
    FOR devIdx := 0 TO 19 DO
        GVL.Voltage[devIdx] := FALSE;
        GVL.Current[devIdx] := FALSE;
        GVL.Standby[devIdx] := FALSE;
        GVL.OperationOn[devIdx] := FALSE;
        GVL.Direction[devIdx] := FALSE;
        GVL.OutputOn[devIdx] := FALSE;
        GVL.OrangeStop[devIdx] := FALSE;
        GVL.RedStop[devIdx] := FALSE;
        GVL.EStop[devIdx] := FALSE;
        GVL.Vin[devIdx] := 0;
        GVL.Vout[devIdx] := 0;
        GVL.Iout[devIdx] := 0;
        GVL.Temperature[devIdx] := 0;
        GVL.FanSpeed1[devIdx] := 0;
        GVL.FanSpeed2[devIdx] := 0;
        GVL.Iin[devIdx] := 0;
        GVL.FaultStatus[devIdx] := 0;
        GVL.TemperatureFaultHigh[devIdx] := FALSE;
        CanCtrlConfigured[devIdx] := FALSE;
    END_FOR;
    GVL.FirstRun := FALSE;
END_IF;

watchDog := NOT watchDog;


// Detect Morphee initialization request (GVL.NumericInput[2] changes)
IF GVL.NumericInput[2] <> LastMorpheeSignal AND NOT updatingInMorpheeTableInprogress THEN
    LastMorpheeSignal := DWORD_TO_UINT(GVL.NumericInput[2]);
    CASE GVL.NumericInput[2] OF
        1..6: // Morphee requests initialization cycles 1 to 6
            IsInitPhase := TRUE;
            InitCycle := DWORD_TO_UINT(GVL.NumericInput[2]);
            initTimeoutCounter := 0;
            InitTimeout(IN := FALSE);
        100: // Morphee signals completion
            IsInitPhase := FALSE;
            InitCycle := 0;
            initTimeoutCounter := 0;
            InitTimeout(IN := FALSE);
    END_CASE;
END_IF;

(* In temporary setpoint test mode, keep normal output update path active. *)
IF GVL.UseTempGroupInputs THEN
  IsInitPhase := FALSE;
  InitCycle := 0;
END_IF;

// Initialization phase logic
IF IsInitPhase THEN
    initTimeoutCounter := initTimeoutCounter + 1;
    // Remove strict timeout to ensure all cycles complete
    // IF initTimeoutCounter > 1000 THEN
    //     IsInitPhase := FALSE;
    //     InitCycle := 0;
    //     initTimeoutCounter := 0;
    //     InitTimeout(IN := FALSE);
    // END_IF;

    InitTimeout(IN := TRUE, PT := T#100MS);

    IF InitCycle > 0 AND IsInitPhase THEN
        updatingInMorpheeTableInprogress := TRUE;
        FOR devIdx := 0 TO 19 DO
            idx := devIdx * 6; // Base index for the device
            IF idx + 5 < 120 THEN // Ensure within array bounds
                CASE InitCycle OF
                    1: // 0x80 and 0x81 (bytes 0-11)
                        cmdId := 16#80;
                        baseIdx := 0;
                        IF baseIdx + 1 < 54 THEN
                            GVL.NumericOutput[idx] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 1]);
                            GVL.NumericOutput[idx + 1] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 2]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 3]);
                            GVL.NumericOutput[idx + 2] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 4]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 5]);
                        END_IF;
                        cmdId := 16#81;
                        baseIdx := 6;
                        IF baseIdx + 1 < 54 THEN
                            GVL.NumericOutput[idx + 3] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 1]);
                            GVL.NumericOutput[idx + 4] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 2]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 3]);
                            GVL.NumericOutput[idx + 5] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 4]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 5]);
                        END_IF;
                    2: // 0x82 and 0x83 (bytes 12-23)
                        cmdId := 16#82;
                        baseIdx := 12;
                        IF baseIdx + 1 < 54 THEN
                            GVL.NumericOutput[idx] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 1]);
                            GVL.NumericOutput[idx + 1] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 2]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 3]);
                            GVL.NumericOutput[idx + 2] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 4]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 5]);
                        END_IF;
                        cmdId := 16#83;
                        baseIdx := 18;
                        IF baseIdx + 1 < 54 THEN
                            GVL.NumericOutput[idx + 3] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 1]);
                            GVL.NumericOutput[idx + 4] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 2]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 3]);
                            GVL.NumericOutput[idx + 5] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 4]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 5]);
                        END_IF;
                    3: // 0x84 (bytes 24-29)
                        cmdId := 16#84;
                        baseIdx := 24;
                        IF baseIdx + 1 < 54 THEN
                            GVL.NumericOutput[idx] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 1]);
                            GVL.NumericOutput[idx + 1] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 2]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 3]);
                            GVL.NumericOutput[idx + 2] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 4]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 5]);
                        END_IF;
                    4: // 0x85 (bytes 30-35)
                        cmdId := 16#85;
                        baseIdx := 30;
                        IF baseIdx + 1 < 54 THEN
                            GVL.NumericOutput[idx] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 1]);
                            GVL.NumericOutput[idx + 1] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 2]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 3]);
                            GVL.NumericOutput[idx + 2] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 4]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 5]);
                        END_IF;
                    5: // 0x86 (bytes 36-41)
                        cmdId := 16#86;
                        baseIdx := 36;
                        IF baseIdx + 1 < 54 THEN
                            GVL.NumericOutput[idx] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 1]);
                            GVL.NumericOutput[idx + 1] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 2]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 3]);
                            GVL.NumericOutput[idx + 2] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 4]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 5]);
                        END_IF;
                    6: // 0x87 and 0x88 (bytes 42-53)
                        cmdId := 16#87;
                        baseIdx := 42;
                        IF baseIdx + 1 < 54 THEN
                            GVL.NumericOutput[idx] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 1]);
                            GVL.NumericOutput[idx + 1] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 2]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 3]);
                            GVL.NumericOutput[idx + 2] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 4]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 5]);
                        END_IF;
                        cmdId := 16#88;
                        baseIdx := 48;
                        IF baseIdx + 1 < 54 THEN
                            GVL.NumericOutput[idx + 3] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 1]);
                            GVL.NumericOutput[idx + 4] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 2]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 3]);
                            GVL.NumericOutput[idx + 5] := SHL(TO_DWORD(cmdId), 24) OR SHL(TO_DWORD(devIdx), 16) OR SHL(TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 4]), 8) OR TO_DWORD(GVL.MfrSerialPersistent[devIdx][baseIdx + 5]);
                        END_IF;
                END_CASE;
            END_IF;
        END_FOR;
        updatingInMorpheeTableInprogress := FALSE;
    END_IF;
ELSE
    updatingInMorpheeTableInprogress := FALSE;
    InitTimeout(IN := FALSE);
    systemAlarms := UINT_TO_DWORD(GVL.SystemAlarms);
    maintenanceMode := (GVL.NumericInput[1] AND 16#0001) <> 0;

    FOR devIdx := 0 TO 19 DO
        baseIdx := devIdx * 5;
        // IF baseIdx < SIZEOF(GVL.NumericOutput) / SIZEOF(GVL.NumericOutput[0]) THEN
            (* Check for RedStop condition *)
            IF GVL.RedStop[devIdx] THEN
                GVL.Voltage[devIdx] := FALSE;
                GVL.Current[devIdx] := FALSE;
                GVL.Standby[devIdx] := TRUE;
                GVL.OperationOn[devIdx] := FALSE;
                GVL.Direction[devIdx] := FALSE;
                GVL.OutputOn[devIdx] := FALSE;
                GVL.OrangeStop[devIdx] := FALSE;
            END_IF;

            IF devIdx <= 3 THEN
              (* DPU fixed scaling from manual: VIN F=1, VOUT F=0.1.
                 Publish raw VOUT (242 = 24.2V) for Morphee to interpret at F=0.1 scale. *)
              scaledVin := GVL.Vin[devIdx];
              scaledVout := GVL.Vout[devIdx];
            ELSE
              (* Commissioning: export BIC VIN as raw x10 engineering units (21.4V -> 214). *)
              scaledVin := GVL.Vin[devIdx];

              (* Scale GVL.Vout[devIdx] using VOUT scaling factor, byte 0 bits 0-3 *)
              (* Publish BIC Vout as fixed-point x100 on EtherCAT so 24.00V is sent as 2400. *)
              tempScale := GVL.VoutScale[devIdx] AND 16#0F; (* Extract bits 0-3 *)
              IF tempScale = 16#4 THEN
                scaledVout := REAL_TO_UINT(UINT_TO_REAL(GVL.Vout[devIdx]) * 0.1);
              ELSIF tempScale = 16#5 THEN
                scaledVout := GVL.Vout[devIdx];
              ELSIF tempScale = 16#6 THEN
                scaledVout := REAL_TO_UINT(UINT_TO_REAL(GVL.Vout[devIdx]) * 10.0);
              ELSIF tempScale = 16#7 THEN
                scaledVout := REAL_TO_UINT(UINT_TO_REAL(GVL.Vout[devIdx]) * 100.0);
              ELSIF tempScale = 16#8 THEN
                scaledVout := REAL_TO_UINT(UINT_TO_REAL(GVL.Vout[devIdx]) * 1000.0);
              ELSIF tempScale = 16#9 THEN
                scaledVout := REAL_TO_UINT(UINT_TO_REAL(GVL.Vout[devIdx]) * 10000.0);
              ELSE
                scaledVout := GVL.Vout[devIdx];
              END_IF;
            END_IF;

            IF GVL.Vin[devIdx] > 0 OR GVL.Vout[devIdx] > 0 THEN
              GVL.NumericOutput[baseIdx] := SHL(TO_DWORD(scaledVin), 16) OR TO_DWORD(scaledVout);
            ELSE
                GVL.NumericOutput[baseIdx] := 0;
            END_IF;

            signedIoutRaw := WORD_TO_INT(UINT_TO_WORD(GVL.Iout[devIdx]));
            IF devIdx <= 3 THEN
              scaledIout := REAL_TO_INT(INT_TO_REAL(signedIoutRaw) * 0.1);
              (* DPU fixed scaling from manual: TEMPERATURE F=0.1.
                 Publish raw value (e.g., 253 = 25.3C) so Morphee applies F=0.1 consistently. *)
              scaledTemp := GVL.Temperature[devIdx];
            ELSE
              (* Scale GVL.Iout[devIdx] using IOUT scaling factor, byte 0 bits 4-7 *)
              tempScale := GVL.VoutScale[devIdx] AND 16#F0; (* Mask bits 4-7 *)
              scaleValue := SHR(tempScale, 4); (* Shift right by 4 to get IOUT bits *)
              IF scaleValue = 16#4 THEN
                scaledIout := REAL_TO_INT(INT_TO_REAL(signedIoutRaw) * 0.001);
              ELSIF scaleValue = 16#5 THEN
                scaledIout := REAL_TO_INT(INT_TO_REAL(signedIoutRaw) * 0.01);
              ELSIF scaleValue = 16#6 THEN
                scaledIout := REAL_TO_INT(INT_TO_REAL(signedIoutRaw) * 0.1);
              ELSIF scaleValue = 16#7 THEN
                scaledIout := signedIoutRaw;
              ELSIF scaleValue = 16#8 THEN
                scaledIout := REAL_TO_INT(INT_TO_REAL(signedIoutRaw) * 10.0);
              ELSIF scaleValue = 16#9 THEN
                scaledIout := REAL_TO_INT(INT_TO_REAL(signedIoutRaw) * 100.0);
              ELSE
                scaledIout := REAL_TO_INT(INT_TO_REAL(signedIoutRaw) * 0.1);
              END_IF;

              (* Scale GVL.Temperature[devIdx] using TEMPERATURE_1 scaling factor, byte 2 bits 0-3 *)
              tempScale := GVL.TempScale[devIdx] AND 16#0F; (* Extract bits 0-3 *)
              IF tempScale = 16#4 THEN
                scaledTemp := REAL_TO_UINT(UINT_TO_REAL(GVL.Temperature[devIdx]) * 0.001);
              ELSIF tempScale = 16#5 THEN
                scaledTemp := REAL_TO_UINT(UINT_TO_REAL(GVL.Temperature[devIdx]) * 0.01);
              ELSIF tempScale = 16#6 THEN
                scaledTemp := REAL_TO_UINT(UINT_TO_REAL(GVL.Temperature[devIdx]) * 0.1);
              ELSIF tempScale = 16#7 THEN
                scaledTemp := GVL.Temperature[devIdx];
              ELSIF tempScale = 16#8 THEN
                scaledTemp := REAL_TO_UINT(UINT_TO_REAL(GVL.Temperature[devIdx]) * 10.0);
              ELSIF tempScale = 16#9 THEN
                scaledTemp := REAL_TO_UINT(UINT_TO_REAL(GVL.Temperature[devIdx]) * 100.0);
              ELSE
                scaledTemp := REAL_TO_UINT(UINT_TO_REAL(GVL.Temperature[devIdx]) * 0.1);
              END_IF;
            END_IF;

            (* Scale GVL.FanSpeed1[devIdx] and GVL.FanSpeed2[devIdx] using FAN_SPEED scaling factor, byte 1 bits 4-7 *)
            tempScale := GVL.VinScale[devIdx] AND 16#F0; (* Mask bits 4-7 *)
            scaleValue := SHR(tempScale, 4); (* Shift right by 4 to get FAN_SPEED bits *)
            IF scaleValue = 16#4 THEN
                scaledFanSpeed1 := REAL_TO_UINT(UINT_TO_REAL(GVL.FanSpeed1[devIdx]) * 0.001);
                scaledFanSpeed2 := REAL_TO_UINT(UINT_TO_REAL(GVL.FanSpeed2[devIdx]) * 0.001);
            ELSIF scaleValue = 16#5 THEN
                scaledFanSpeed1 := REAL_TO_UINT(UINT_TO_REAL(GVL.FanSpeed1[devIdx]) * 0.01);
                scaledFanSpeed2 := REAL_TO_UINT(UINT_TO_REAL(GVL.FanSpeed2[devIdx]) * 0.01);
            ELSIF scaleValue = 16#6 THEN
                scaledFanSpeed1 := REAL_TO_UINT(UINT_TO_REAL(GVL.FanSpeed1[devIdx]) * 0.1);
                scaledFanSpeed2 := REAL_TO_UINT(UINT_TO_REAL(GVL.FanSpeed2[devIdx]) * 0.1);
            ELSIF scaleValue = 16#7 THEN
                scaledFanSpeed1 := GVL.FanSpeed1[devIdx];
                scaledFanSpeed2 := GVL.FanSpeed2[devIdx];
            ELSIF scaleValue = 16#8 THEN
                scaledFanSpeed1 := REAL_TO_UINT(UINT_TO_REAL(GVL.FanSpeed1[devIdx]) * 10.0);
                scaledFanSpeed2 := REAL_TO_UINT(UINT_TO_REAL(GVL.FanSpeed2[devIdx]) * 10.0);
            ELSIF scaleValue = 16#9 THEN
                scaledFanSpeed1 := REAL_TO_UINT(UINT_TO_REAL(GVL.FanSpeed1[devIdx]) * 100.0);
                scaledFanSpeed2 := REAL_TO_UINT(UINT_TO_REAL(GVL.FanSpeed2[devIdx]) * 100.0);
            ELSE
              scaledFanSpeed1 := GVL.FanSpeed1[devIdx];
              scaledFanSpeed2 := GVL.FanSpeed2[devIdx];
            END_IF;

            (* Scale GVL.Iin[devIdx] using IIN scaling factor, byte 3 bits 0-3 *)
            tempScale := GVL.IinScale[devIdx] AND 16#0F; (* Extract bits 0-3 *)
            IF tempScale = 16#4 THEN
                scaledIin := REAL_TO_UINT(UINT_TO_REAL(GVL.Iin[devIdx]) * 0.001);
            ELSIF tempScale = 16#5 THEN
                scaledIin := REAL_TO_UINT(UINT_TO_REAL(GVL.Iin[devIdx]) * 0.01);
            ELSIF tempScale = 16#6 THEN
                scaledIin := REAL_TO_UINT(UINT_TO_REAL(GVL.Iin[devIdx]) * 0.1);
            ELSIF tempScale = 16#7 THEN
                scaledIin := GVL.Iin[devIdx];
            ELSIF tempScale = 16#8 THEN
                scaledIin := REAL_TO_UINT(UINT_TO_REAL(GVL.Iin[devIdx]) * 10.0);
            ELSIF tempScale = 16#9 THEN
                scaledIin := REAL_TO_UINT(UINT_TO_REAL(GVL.Iin[devIdx]) * 100.0);
            ELSE
                scaledIin := REAL_TO_UINT(UINT_TO_REAL(GVL.Iin[devIdx]) * 0.1);
            END_IF;

            (* For BIC group masters, publish aggregated group feedback in the same device channels
               so EtherCAT master can keep reading per-master channels without remapping. *)
            IF devIdx >= 4 THEN
              CASE devIdx OF
                4..7: groupIdx := 0;
                8..11: groupIdx := 1;
                12..15: groupIdx := 2;
                16..19: groupIdx := 3;
                ELSE groupIdx := -1;
              END_CASE;

              IF groupIdx >= 0 AND groupIdx <= 3 AND GVL.GroupMaster[groupIdx] = devIdx THEN
                groupBase := (groupIdx * 4) + 4;
                groupAggVinRaw := 0;
                groupAggVoutRaw := 0;
                groupAggIoutRaw := 0;
                groupMaxTempRaw := 0;
                groupMinFan1Raw := 16#FFFF;
                groupMinFan2Raw := 16#FFFF;
                groupActiveCount := 0;

                FOR memberIdx := groupBase TO groupBase + 3 DO
                  IF memberIdx <= 19 THEN
                    IF GVL.Vin[memberIdx] > 0 AND NOT GVL.CommFault[memberIdx] AND NOT GVL.SafetyShutdown[memberIdx] THEN
                      groupActiveCount := groupActiveCount + 1;
                      groupAggVinRaw := groupAggVinRaw + UINT_TO_UDINT(GVL.Vin[memberIdx]);
                      groupAggVoutRaw := groupAggVoutRaw + UINT_TO_UDINT(GVL.Vout[memberIdx]);
                      groupAggIoutRaw := groupAggIoutRaw + INT_TO_DINT(WORD_TO_INT(UINT_TO_WORD(GVL.Iout[memberIdx])));
                      groupMaxTempRaw := MAX(groupMaxTempRaw, GVL.Temperature[memberIdx]);
                      IF GVL.FanSpeed1[memberIdx] < groupMinFan1Raw THEN
                        groupMinFan1Raw := GVL.FanSpeed1[memberIdx];
                      END_IF;
                      IF GVL.FanSpeed2[memberIdx] < groupMinFan2Raw THEN
                        groupMinFan2Raw := GVL.FanSpeed2[memberIdx];
                      END_IF;
                    END_IF;
                  END_IF;
                END_FOR;

                IF groupActiveCount > 0 THEN
                  groupAvgVinRaw := groupAggVinRaw / UINT_TO_UDINT(groupActiveCount);
                  groupAvgVoutRaw := groupAggVoutRaw / UINT_TO_UDINT(groupActiveCount);

                  (* Commissioning: grouped BIC VIN uses raw averaged x10 units. *)
                  scaledVin := UDINT_TO_INT(groupAvgVinRaw);

                  tempScale := GVL.VoutScale[devIdx] AND 16#0F;
                  IF tempScale = 16#4 THEN
                    scaledVout := REAL_TO_UINT(UDINT_TO_REAL(groupAvgVoutRaw) * 0.1);
                  ELSIF tempScale = 16#5 THEN
                    scaledVout := UDINT_TO_UINT(groupAvgVoutRaw);
                  ELSIF tempScale = 16#6 THEN
                    scaledVout := REAL_TO_UINT(UDINT_TO_REAL(groupAvgVoutRaw) * 10.0);
                  ELSIF tempScale = 16#7 THEN
                    scaledVout := REAL_TO_UINT(UDINT_TO_REAL(groupAvgVoutRaw) * 100.0);
                  ELSIF tempScale = 16#8 THEN
                    scaledVout := REAL_TO_UINT(UDINT_TO_REAL(groupAvgVoutRaw) * 1000.0);
                  ELSIF tempScale = 16#9 THEN
                    scaledVout := REAL_TO_UINT(UDINT_TO_REAL(groupAvgVoutRaw) * 10000.0);
                  ELSE
                    scaledVout := UDINT_TO_UINT(groupAvgVoutRaw);
                  END_IF;

                  (* Convert summed raw Iout to exported units using current device scaling. *)
                  tempScale := GVL.VoutScale[devIdx] AND 16#F0;
                  scaleValue := SHR(tempScale, 4);
                  IF scaleValue = 16#4 THEN
                    scaledIout := REAL_TO_INT(DINT_TO_REAL(groupAggIoutRaw) * 0.001);
                  ELSIF scaleValue = 16#5 THEN
                    scaledIout := REAL_TO_INT(DINT_TO_REAL(groupAggIoutRaw) * 0.01);
                  ELSIF scaleValue = 16#6 THEN
                    scaledIout := REAL_TO_INT(DINT_TO_REAL(groupAggIoutRaw) * 0.1);
                  ELSIF scaleValue = 16#7 THEN
                    scaledIout := DINT_TO_INT(groupAggIoutRaw);
                  ELSIF scaleValue = 16#8 THEN
                    scaledIout := REAL_TO_INT(DINT_TO_REAL(groupAggIoutRaw) * 10.0);
                  ELSIF scaleValue = 16#9 THEN
                    scaledIout := REAL_TO_INT(DINT_TO_REAL(groupAggIoutRaw) * 100.0);
                  ELSE
                    scaledIout := REAL_TO_INT(DINT_TO_REAL(groupAggIoutRaw) * 0.1);
                  END_IF;

                  (* Group thermal feedback uses hottest healthy unit in the group. *)
                  tempScale := GVL.TempScale[devIdx] AND 16#0F;
                  IF tempScale = 16#4 THEN
                    scaledTemp := REAL_TO_UINT(UINT_TO_REAL(groupMaxTempRaw) * 0.001);
                  ELSIF tempScale = 16#5 THEN
                    scaledTemp := REAL_TO_UINT(UINT_TO_REAL(groupMaxTempRaw) * 0.01);
                  ELSIF tempScale = 16#6 THEN
                    scaledTemp := REAL_TO_UINT(UINT_TO_REAL(groupMaxTempRaw) * 0.1);
                  ELSIF tempScale = 16#7 THEN
                    scaledTemp := groupMaxTempRaw;
                  ELSIF tempScale = 16#8 THEN
                    scaledTemp := REAL_TO_UINT(UINT_TO_REAL(groupMaxTempRaw) * 10.0);
                  ELSIF tempScale = 16#9 THEN
                    scaledTemp := REAL_TO_UINT(UINT_TO_REAL(groupMaxTempRaw) * 100.0);
                  ELSE
                    scaledTemp := REAL_TO_UINT(UINT_TO_REAL(groupMaxTempRaw) * 0.1);
                  END_IF;

                  (* Group fan feedback uses the lowest healthy fan speed per fan channel. *)
                  tempScale := GVL.VinScale[devIdx] AND 16#F0;
                  scaleValue := SHR(tempScale, 4);
                  IF scaleValue = 16#4 THEN
                    scaledFanSpeed1 := REAL_TO_UINT(UINT_TO_REAL(groupMinFan1Raw) * 0.001);
                    scaledFanSpeed2 := REAL_TO_UINT(UINT_TO_REAL(groupMinFan2Raw) * 0.001);
                  ELSIF scaleValue = 16#5 THEN
                    scaledFanSpeed1 := REAL_TO_UINT(UINT_TO_REAL(groupMinFan1Raw) * 0.01);
                    scaledFanSpeed2 := REAL_TO_UINT(UINT_TO_REAL(groupMinFan2Raw) * 0.01);
                  ELSIF scaleValue = 16#6 THEN
                    scaledFanSpeed1 := REAL_TO_UINT(UINT_TO_REAL(groupMinFan1Raw) * 0.1);
                    scaledFanSpeed2 := REAL_TO_UINT(UINT_TO_REAL(groupMinFan2Raw) * 0.1);
                  ELSIF scaleValue = 16#7 THEN
                    scaledFanSpeed1 := groupMinFan1Raw;
                    scaledFanSpeed2 := groupMinFan2Raw;
                  ELSIF scaleValue = 16#8 THEN
                    scaledFanSpeed1 := REAL_TO_UINT(UINT_TO_REAL(groupMinFan1Raw) * 10.0);
                    scaledFanSpeed2 := REAL_TO_UINT(UINT_TO_REAL(groupMinFan2Raw) * 10.0);
                  ELSIF scaleValue = 16#9 THEN
                    scaledFanSpeed1 := REAL_TO_UINT(UINT_TO_REAL(groupMinFan1Raw) * 100.0);
                    scaledFanSpeed2 := REAL_TO_UINT(UINT_TO_REAL(groupMinFan2Raw) * 100.0);
                  ELSE
                    scaledFanSpeed1 := groupMinFan1Raw;
                    scaledFanSpeed2 := groupMinFan2Raw;
                  END_IF;
                ELSE
                  scaledVin := 0;
                  scaledVout := 0;
                  scaledIout := 0;
                  scaledTemp := 0;
                  scaledFanSpeed1 := 0;
                  scaledFanSpeed2 := 0;
                END_IF;
              END_IF;
            END_IF;

            GVL.NumericOutput[baseIdx] := SHL(TO_DWORD(scaledVin), 16) OR TO_DWORD(scaledVout);
            GVL.NumericOutput[baseIdx + 1] := SHL(TO_DWORD(INT_TO_WORD(scaledIout)), 16) OR TO_DWORD(scaledTemp);
            GVL.NumericOutput[baseIdx + 2] := SHL(TO_DWORD(scaledFanSpeed1), 16) OR TO_DWORD(scaledFanSpeed2);

            groupFaultStatusAgg := GVL.FaultStatus[devIdx];
            aggDirection := GVL.Direction[devIdx];
            aggOperationOn := GVL.OperationOn[devIdx];
            aggCurrentMode := GVL.Current[devIdx];
            aggVoltageMode := GVL.Voltage[devIdx];
            aggOutputOn := GVL.OutputOn[devIdx];
            aggOrangeStop := GVL.OrangeStop[devIdx];
            aggRedStop := GVL.RedStop[devIdx];
            aggEStop := GVL.EStop[devIdx];
            aggTempFaultHigh := GVL.TemperatureFaultHigh[devIdx];

            IF devIdx >= 4 THEN
              CASE devIdx OF
                4..7: groupIdx := 0;
                8..11: groupIdx := 1;
                12..15: groupIdx := 2;
                16..19: groupIdx := 3;
                ELSE groupIdx := -1;
              END_CASE;

              IF groupIdx >= 0 AND groupIdx <= 3 AND GVL.GroupMaster[groupIdx] = devIdx THEN
                groupBase := (groupIdx * 4) + 4;
                groupFaultStatusAgg := 0;
                aggDirection := FALSE;
                aggOperationOn := FALSE;
                aggCurrentMode := FALSE;
                aggVoltageMode := FALSE;
                aggOutputOn := FALSE;
                aggOrangeStop := FALSE;
                aggRedStop := FALSE;
                aggEStop := FALSE;
                aggTempFaultHigh := FALSE;

                FOR memberIdx := groupBase TO groupBase + 3 DO
                  IF memberIdx <= 19 THEN
                    groupFaultStatusAgg := groupFaultStatusAgg OR GVL.FaultStatus[memberIdx];
                    aggDirection := aggDirection OR GVL.Direction[memberIdx];
                    aggOperationOn := aggOperationOn OR GVL.OperationOn[memberIdx];
                    aggCurrentMode := aggCurrentMode OR GVL.Current[memberIdx];
                    aggVoltageMode := aggVoltageMode OR GVL.Voltage[memberIdx];
                    aggOutputOn := aggOutputOn OR GVL.OutputOn[memberIdx];
                    aggOrangeStop := aggOrangeStop OR GVL.OrangeStop[memberIdx];
                    aggRedStop := aggRedStop OR GVL.RedStop[memberIdx];
                    aggEStop := aggEStop OR GVL.EStop[memberIdx];
                    aggTempFaultHigh := aggTempFaultHigh OR GVL.TemperatureFaultHigh[memberIdx];
                  END_IF;
                END_FOR;
              END_IF;
            END_IF;

            GVL.NumericOutput[baseIdx + 3] := SHL(TO_DWORD(groupFaultStatusAgg), 16) OR 
                                              SHL(TO_DWORD(aggDirection), 0) OR 
                                              SHL(TO_DWORD(aggOperationOn), 1) OR 
                                              SHL(TO_DWORD(aggCurrentMode), 2) OR 
                                              SHL(TO_DWORD(aggVoltageMode), 3) OR 
                                              SHL(TO_DWORD(aggOutputOn), 4) OR 
                                              SHL(TO_DWORD(aggOrangeStop), 5) OR 
                                              SHL(TO_DWORD(aggRedStop), 6) OR 
                                              SHL(TO_DWORD(aggEStop), 7) OR 
                                              SHL(TO_DWORD(aggTempFaultHigh), 8);
            systemFlagsOut := GVL.DeviceSystemFlags[devIdx];
            IF devIdx >= 4 THEN
              CASE devIdx OF
                4..7: groupIdx := 0;
                8..11: groupIdx := 1;
                12..15: groupIdx := 2;
                16..19: groupIdx := 3;
                ELSE groupIdx := -1;
              END_CASE;

              IF groupIdx >= 0 AND groupIdx <= 3 AND GVL.GroupMaster[groupIdx] = devIdx THEN
                systemFlagsOut := systemFlagsOut OR 16#0001;   (* M/S bit0 = 1 for group master *)
              ELSE
                systemFlagsOut := systemFlagsOut AND 16#FFFE;  (* M/S bit0 = 0 for non-master in group *)
              END_IF;
            END_IF;

            GVL.NumericOutput[baseIdx + 4] := SHL(TO_DWORD(systemFlagsOut), 16);
        //END_IF;
    END_FOR;

    GVL.NumericOutput[100] := systemAlarms;
	 EL3174_Channel1_Alarm:=  EL3174_Channel1_value>(2.5*10)/32768;
 	 EL3174_Channel2_Alarm:=  EL3174_Channel2_value>(2.5*10)/32768;
 	 EL3174_Channel3_Alarm:=  EL3174_Channel3_value>(2.5*10)/32768;
	 EL3174_Channel4_Alarm:=  EL3174_Channel4_value>(2.5*10)/32768;
    GVL.NumericOutput[101] := SHL(TO_DWORD(GVL.SystemFlags), 0) OR 
                              SHL(TO_DWORD(GVL.EthercatAliveFromMaster), 2) OR 
                              SHL(TO_DWORD(GVL.RemoteMasterAlive), 3) OR 
                              SHL(TO_DWORD(watchDog), 4) OR 
                              SHL(TO_DWORD(DataRefreshRequired), 5) OR
                              SHL(TO_DWORD(IsInitPhase), 6) OR 
							  SHL(TO_DWORD(EL3174_Channel1_Alarm), 7) OR 
							  SHL(TO_DWORD(EL3174_Channel2_Alarm), 8) OR 
							  SHL(TO_DWORD(EL3174_Channel3_Alarm), 9) OR 
							  SHL(TO_DWORD(EL3174_Channel4_Alarm), 10);
    GVL.NumericOutput[102] := SHL(TO_DWORD(GVL.GroupMaster[0]), 16) OR TO_DWORD(GVL.GroupMaster[1]);
    GVL.NumericOutput[103] := SHL(TO_DWORD(GVL.GroupMaster[2]), 16) OR TO_DWORD(GVL.GroupMaster[3]);

   // GVL.NumericOutput[100] := systemAlarms;
     absVminX100 := GVL_Constant.MIN_VOLTAGE * 100;
     absVmaxX100 := GVL_Constant.MAX_VOLTAGE * 100;

     (* Absolute voltage limits exported for Morphee operator UI (x100 V), per group. *)
     FOR groupIdx := 0 TO 3 DO
      GVL.NumericOutput[104 + groupIdx] := SHL(TO_DWORD(absVminX100), 16) OR TO_DWORD(absVmaxX100);
     END_FOR;

     GVL.NumericOutput[108] := UINT_TO_DWORD(GVL.GroupCapacity[0]);
    GVL.NumericOutput[109] := UINT_TO_DWORD(GVL.GroupCapacity[1]);
    GVL.NumericOutput[110] := UINT_TO_DWORD(GVL.GroupCapacity[2]);
    GVL.NumericOutput[111] := UINT_TO_DWORD(GVL.GroupCapacity[3]);

     (* Absolute group current limits exported for Morphee operator UI, scaled x10 A.
       NumericOutput[112..115]: upper = forward hard max, lower = reverse hard max. *)
     perDeviceLimitFwdX10 := REAL_TO_UINT(GVL_Constant.BIC24_IOUT_MAX_FWD * 10.0);
     perDeviceLimitRevX10 := REAL_TO_UINT(GVL_Constant.BIC24_IOUT_MAX_REV * 10.0);
    FOR groupIdx := 0 TO 3 DO
      activeInGroupX10 := 0;
      reverseMode := FALSE;
      groupBase := (groupIdx * 4) + 4;

      FOR devIdx := groupBase TO groupBase + 3 DO
        IF devIdx <= 19 THEN
          IF GVL.Direction[devIdx] THEN
            reverseMode := TRUE;
          END_IF;
          IF GVL.Vin[devIdx] > 0 AND NOT GVL.CommFault[devIdx] AND NOT GVL.SafetyShutdown[devIdx] THEN
            activeInGroupX10 := activeInGroupX10 + 1;
          END_IF;
        END_IF;
      END_FOR;

      IF reverseMode THEN
        perDeviceLimitX10 := REAL_TO_UINT(GVL_Constant.BIC24_IOUT_MAX_REV * 10.0);
      ELSE
        perDeviceLimitX10 := REAL_TO_UINT(GVL_Constant.BIC24_IOUT_MAX_FWD * 10.0);
      END_IF;

      groupLimitFwdX10 := activeInGroupX10 * perDeviceLimitFwdX10;
      groupLimitRevX10 := activeInGroupX10 * perDeviceLimitRevX10;
      GVL.NumericOutput[112 + groupIdx] := SHL(TO_DWORD(groupLimitFwdX10), 16) OR TO_DWORD(groupLimitRevX10);
    END_FOR;

     (* DIAGNOSTIC: Group 3/4 isolation verification in valid slots [116..120].
       Note: some HMI links show only low 16-bit values from DWORD tags, so publish one value per slot.
       [116] raw Group3 Vout input  = NumericInput[GroupInputBase[2]]
       [117] raw Group4 Vout input  = NumericInput[GroupInputBase[3]]
       [118] applied Group3 VoutSetpoint (dev12, x100 engineering)
       [119] applied Group4 VoutSetpoint (dev16, x100 engineering)
       [120] absolute command delta = ABS(LastVoutSetpoint[12] - LastVoutSetpoint[16]); 0 means both groups are being commanded identically *)
     (* [116] LastVoutSetpoint[12]: last Vout CAN command sent to dev12 (Group3 first BIC) *)
     GVL.NumericOutput[116] := TO_DWORD(LastVoutSetpoint[12]);
     (* [117] LastVoutSetpoint[16]: last Vout CAN command sent to dev16 (Group4 first BIC) *)
     GVL.NumericOutput[117] := TO_DWORD(LastVoutSetpoint[16]);
     (* [118] Dev12 mode flags: bit0=Voltage, bit1=Current, bit2=OutputOn, bit3=OperationOn, bits 8-11 same for dev16 *)
     GVL.NumericOutput[118] := SHL(TO_DWORD(GVL.Voltage[12]), 0) OR
                                SHL(TO_DWORD(GVL.Current[12]), 1) OR
                                SHL(TO_DWORD(GVL.OutputOn[12]), 2) OR
                                SHL(TO_DWORD(GVL.OperationOn[12]), 3) OR
                                SHL(TO_DWORD(GVL.Voltage[16]), 8) OR
                                SHL(TO_DWORD(GVL.Current[16]), 9) OR
                                SHL(TO_DWORD(GVL.OutputOn[16]), 10) OR
                                SHL(TO_DWORD(GVL.OperationOn[16]), 11);
     (* [119] GroupMaster[2] (G3) and GroupMaster[3] (G4); -1 = no master assigned *)
     GVL.NumericOutput[119] := SHL(TO_DWORD(INT_TO_UINT(GVL.GroupMaster[2])), 16) OR TO_DWORD(INT_TO_UINT(GVL.GroupMaster[3]));
     (* [120] Raw NumericInput[GroupInputBase[2]] = Group3 Vout input; compare with [117] to check Morphee PDO *)
     GVL.NumericOutput[120] := TO_DWORD(GVL.NumericInput[GVL.GroupInputBase[3]]);
END_IF;]]></ST>
      </Implementation>
    </Method>
